# Cloudflare Pages — Security Headers
# Applied to all routes unless overridden below

/*
  # HSTS — force HTTPS for 2 years, include subdomains, preload-ready
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Prevent clickjacking
  X-Frame-Options: SAMEORIGIN

  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Control referrer information
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser feature permissions
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()

  # Content Security Policy
  # - Scripts: self + GTM + Facebook Pixel + inline (required for Astro JSON-LD)
  # - Styles: self + unsafe-inline (required for Tailwind v4 runtime)
  # - Fonts: self only (self-hosted Sora + DM Sans)
  # - Images: self + data URIs + HTTPS (for OG images, portfolio, blog)
  # - Frames: Calendly + Google Maps only
  # - form-action: self only (API routes)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://connect.facebook.net; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com; frame-src 'self' https://calendly.com https://www.google.com/maps https://maps.google.com; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests

  # Cross-Origin policies
  Cross-Origin-Embedder-Policy: unsafe-none
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site

  # Remove server fingerprinting
  X-Powered-By: none

  # Cache control for HTML pages — always revalidate
  Cache-Control: public, max-age=0, must-revalidate

# Static assets — aggressive caching (content-hashed filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Public images — cache for 30 days
/images/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/portfolio/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/blog/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/team/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# Fonts — cache for 1 year (immutable)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon
/favicon.ico
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=86400

# Sitemap + robots — short cache so search engines get fresh copies
/sitemap-index.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=3600

# API routes — no caching, no indexing frame
/api/*
  Cache-Control: no-store, no-cache
  X-Robots-Tag: noindex, nofollow

# Thank-you page — no indexing
/thank-you
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store
