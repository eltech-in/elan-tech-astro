---
import BaseLayout from '../layouts/BaseLayout.astro';

const quickLinks = [
  { href: '/', label: 'Home', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>` },
  { href: '/services', label: 'Services', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>` },
  { href: '/portfolio', label: 'Portfolio', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>` },
  { href: '/blog', label: 'Blog', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>` },
  { href: '/contact', label: 'Contact', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>` },
  { href: '/get-quote', label: 'Get Quote', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>` },
];
---

<BaseLayout
  title="Page Not Found — eLan Technology"
  description="The page you're looking for doesn't exist."
  noindex={true}
>

  <section class="bg-[var(--bg)] py-24 md:py-32">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">

      <!-- Faded 404 + H1 overlaid -->
      <div class="relative flex flex-col items-center justify-center mb-8">
        <span
          class="select-none font-heading font-bold leading-none text-[var(--accent)]/10"
          style="font-size: clamp(8rem, 25vw, 16rem);"
          aria-hidden="true"
        >
          404
        </span>
        <h1 class="font-heading text-4xl sm:text-5xl font-bold text-[var(--text)] absolute">
          Page Not Found
        </h1>
      </div>

      <p class="text-lg text-[var(--text-dim)] leading-relaxed mb-12 max-w-xl mx-auto">
        The page you're looking for has moved, been renamed, or doesn't exist. Use the links below to find what you need.
      </p>


      <!-- Quick links grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-12">
        {quickLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-5 flex flex-col items-center gap-3 hover:border-[var(--accent)] hover:bg-[var(--accent)]/5 transition-colors group"
          >
            <span class="text-[var(--text-muted)] group-hover:text-[var(--accent)] transition-colors" set:html={link.icon} />
            <span class="text-sm font-medium text-[var(--text)] group-hover:text-[var(--accent)] transition-colors">{link.label}</span>
          </a>
        ))}
      </div>


      <!-- Back to home CTA -->
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-4 text-base font-semibold text-[#0A0E1A] hover:opacity-90 transition-opacity"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        Back to Home
      </a>

    </div>
  </section>

</BaseLayout>
