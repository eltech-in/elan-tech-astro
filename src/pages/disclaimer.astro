---
import LegalLayout from '../layouts/LegalLayout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import { webPageSchema, breadcrumbSchema } from '../utils/schema';

const schema = [
  webPageSchema('Disclaimer', 'eLan Technology disclaimer — limitations on website information and service guarantees.', '/disclaimer'),
  breadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Disclaimer', url: '/disclaimer' }]),
];
---
<LegalLayout
  title="Disclaimer"
  description="eLan Technology disclaimer — limitations on website information and service guarantees."
  lastUpdated="2025-01-01"
>
  <SchemaMarkup schema={schema} />

  <h2>General Disclaimer</h2>
  <p>
    The information provided on <a href="https://elan-tech.net">elan-tech.net</a> is intended for
    general informational purposes only. While eLan Technology strives to keep all content accurate,
    current, and complete, we make no representations or warranties of any kind — express or implied
    — about the completeness, accuracy, reliability, suitability, or availability of the information,
    services, or related graphics contained on this website.
  </p>

  <h2>Service Results</h2>
  <p>
    Digital marketing, SEO, and web development results (including but not limited to search engine
    rankings, website traffic, conversion rates, and lead generation) depend on a wide range of
    factors that are outside our direct control, including search engine algorithm changes, market
    conditions, client industry, and competitive landscape. eLan Technology does not guarantee any
    specific outcomes, rankings, or results from the use of our services.
  </p>

  <h2>External Links</h2>
  <p>
    Our website may contain links to third-party websites and resources for your convenience and
    reference. These links do not constitute endorsement of those websites or their content. eLan
    Technology has no control over the nature, content, or availability of those websites and accepts
    no responsibility for their accuracy, legality, or any potential harm arising from their use.
  </p>

  <h2>Testimonials</h2>
  <p>
    Client testimonials and case studies published on this website reflect the individual experiences
    of specific clients and are provided for illustrative purposes only. Results may vary
    significantly between clients. Testimonials are not intended to be guarantees or promises of
    similar outcomes for all clients.
  </p>

