---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { softwareAppSchema, breadcrumbSchema } from '../../utils/schema';
import { getProductBySlug } from '../../data/products';

const product = getProductBySlug('real-estate-portal');

const schema = [
  softwareAppSchema({
    name: product.title,
    description: product.desc,
    url: `/products/${product.slug}`,
    applicationCategory: product.schemaCategory,
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Products', url: '/products' },
    { name: product.title, url: `/products/${product.slug}` },
  ]),
];

// Expanded feature descriptions for the detail page (titles match products.ts features)
const features = [
  { title: 'Comprehensive Listings', desc: 'Manage buying, renting, and selling properties with rich listing pages, photo galleries, and floor plans.' },
  { title: 'Advanced Search Filters', desc: 'Filter by location, budget, BHK configuration, property type, and RERA status.' },
  { title: 'Verified RERA Listings', desc: 'Display RERA registration badges to build buyer trust and legal compliance.' },
  { title: 'Joint Ventures Platform', desc: 'Connect land owners with investors through a dedicated JV matching module.' },
  { title: 'Specialized Categories', desc: 'Handle Agricultural, Commercial, and Residential land with category-specific fields.' },
  { title: 'Agent & Admin Dashboard', desc: 'Centralized dashboards for agents to manage leads, listings, and client communications.' },
  { title: 'Lead Capture & CRM', desc: 'Built-in inquiry forms, WhatsApp integration, and lead tracking for follow-up management.' },
  { title: 'Map Integration', desc: 'Google Maps integration with property pins, neighbourhood overlays, and proximity search.' },
];

const audience = [
  { title: 'Real Estate Agencies', desc: 'Manage multiple agents, listings, and inquiries from a single platform.' },
  { title: 'Property Developers', desc: 'Showcase new projects with phase-wise updates, floor plans, and booking modules.' },
  { title: 'Builders & Contractors', desc: 'List under-construction and completed properties with progress photo galleries.' },
  { title: 'Housing Societies', desc: 'Manage resale listings and connect existing owners with prospective buyers.' },
];

const techStack = ['React', 'Next.js', 'Node.js', 'MongoDB', 'Express', 'AWS S3', 'Google Maps API', 'Razorpay', 'Tailwind CSS', 'TypeScript'];
---

<BaseLayout
  title="Real Estate Portal & Property Management System — eLan Technology"
  description="Custom real estate portal with property listings, agent dashboards, RERA badges, and lead capture. Built for Indian real estate agencies, developers, and builders."
  schema={schema}
>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════════════════════════ -->
  <section aria-labelledby="rep-hero-heading" class="relative overflow-hidden bg-gradient-to-br from-[var(--bg)] to-[var(--bg-card)] py-24 md:py-36">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 -left-40 h-[600px] w-[600px] rounded-full bg-[#00E5A0]/8 blur-[120px]"></div>
      <div class="absolute -bottom-40 -right-20 h-[500px] w-[500px] rounded-full bg-[#00E5A0]/5 blur-[100px]"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-[#00E5A0]/30 bg-[#00E5A0]/10 px-4 py-2 text-sm font-medium text-[#00E5A0]">
        Real Estate Software
      </div>

      <h1
        id="rep-hero-heading"
        class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight text-[var(--text)] mb-6"
      >
        Real Estate Portal
      </h1>

      <p class="mx-auto mb-4 max-w-2xl text-lg text-[#00E5A0] font-medium">
        Property Management &amp; Listing Platform
      </p>

      <p class="mx-auto mb-10 max-w-3xl text-lg text-[var(--text-dim)] leading-relaxed">
        {product.longDesc}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/request-demo"
          class="inline-flex items-center gap-2 rounded-full bg-[#00E5A0] px-8 py-4 text-base font-semibold text-[#0A0E1A] shadow-lg shadow-[#00E5A0]/25 transition-all duration-300 hover:brightness-110 hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#00E5A0]"
        >
          Request Demo
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a
          href="/get-quote"
          class="inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-transparent px-8 py-4 text-base font-semibold text-[var(--text)] transition-all duration-300 hover:border-[#00E5A0] hover:text-[#00E5A0] hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#00E5A0]"
        >
          Get Quote
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       FEATURES GRID
  ════════════════════════════════════════════════════════════════════════ -->
  <section aria-labelledby="rep-features-heading" class="bg-[var(--bg)] py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-center text-sm font-semibold uppercase tracking-widest text-[#00E5A0] mb-3">Key Features</p>
      <h2 id="rep-features-heading" class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] text-center mb-4">
        Everything a Real Estate Business Needs
      </h2>
      <p class="text-center text-[var(--text-dim)] mb-12 max-w-2xl mx-auto">
        From listing management to lead capture, every feature is purpose-built for the Indian real estate market.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((f) => (
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-[#00E5A0]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00E5A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3 class="font-semibold text-[var(--text)] mb-2">{f.title}</h3>
            <p class="text-sm text-[var(--text-dim)] leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       WHO IT'S FOR
  ════════════════════════════════════════════════════════════════════════ -->
  <section aria-labelledby="rep-audience-heading" class="bg-[var(--bg-card)] py-16 md:py-20 border-y border-[var(--border)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-center text-sm font-semibold uppercase tracking-widest text-[#00E5A0] mb-3">Who It's For</p>
      <h2 id="rep-audience-heading" class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] text-center mb-12">
        Built for Real Estate Professionals
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {audience.map((a) => (
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg)] p-6 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[#00E5A0]/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00E5A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <h3 class="font-semibold text-[var(--text)] mb-2">{a.title}</h3>
            <p class="text-sm text-[var(--text-dim)] leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       SCREENSHOTS PLACEHOLDER
  ════════════════════════════════════════════════════════════════════════ -->
  <section aria-labelledby="rep-screenshots-heading" class="bg-[var(--bg)] py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-center text-sm font-semibold uppercase tracking-widest text-[#00E5A0] mb-3">Screenshots</p>
      <h2 id="rep-screenshots-heading" class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] text-center mb-12">
        A Glimpse of the Platform
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          'Property Listings Page — search, filter, map view',
          'Agent Dashboard — leads, enquiries, analytics',
          'Property Detail Page — gallery, floor plan, contact form',
        ].map((caption) => (
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] overflow-hidden">
            <div class="aspect-video w-full bg-[var(--border)]/30 flex items-center justify-center">
              <span class="text-[var(--text-muted)] text-sm">Screenshot Coming Soon</span>
            </div>
            <p class="p-4 text-sm text-[var(--text-dim)] text-center">{caption}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       TECHNOLOGY STACK
  ════════════════════════════════════════════════════════════════════════ -->
  <section aria-labelledby="rep-tech-heading" class="bg-[var(--bg-card)] py-16 md:py-20 border-y border-[var(--border)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-[#00E5A0] mb-3">Technology Stack</p>
      <h2 id="rep-tech-heading" class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] mb-8">
        Built With Modern Technology
      </h2>
      <div class="flex flex-wrap justify-center gap-3">
        {techStack.map((tech) => (
          <span class="rounded-full border border-[#00E5A0]/30 bg-[#00E5A0]/10 px-4 py-2 text-sm font-medium text-[#00E5A0]">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       REQUEST DEMO CTA
  ════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[var(--bg)] py-16 md:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-8 text-center">
        <h2 class="font-heading text-2xl font-bold text-[var(--text)] mb-4">See It In Action</h2>
        <p class="text-[var(--text-dim)] mb-6">
          Schedule a 30-minute live demo of the Real Estate Portal and see exactly how it handles your use case.
        </p>
        <a
          href="/request-demo"
          class="inline-flex items-center gap-2 rounded-full bg-[#00E5A0] px-8 py-3 text-base font-semibold text-[#0A0E1A] hover:opacity-90 transition-opacity"
        >
          Request Demo →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
