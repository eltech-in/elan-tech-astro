---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../utils/schema';

const schema = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Products', url: '/products' },
  { name: 'Request Demo', url: '/request-demo' },
]);

const steps = [
  { step: '1', title: 'Choose Product', desc: 'Select which product you want to see demonstrated.' },
  { step: '2', title: 'Pick a Time', desc: "We'll confirm a 30-minute slot that works for you." },
  { step: '3', title: 'Live Demo + Q&A', desc: 'Our team walks you through the platform live. Ask anything.' },
];
---

<BaseLayout
  title="Request a Product Demo — eLan Technology"
  description="Schedule a free 30-minute live demo of our real estate portal, medical conference portal, IMA society portal, or resort management system."
  schema={schema}
>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════════════════════════ -->
  <section aria-labelledby="demo-hero-heading" class="relative overflow-hidden bg-gradient-to-br from-[var(--bg)] to-[var(--bg-card)] py-24 md:py-32">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 left-1/2 -translate-x-1/2 h-[500px] w-[500px] rounded-full bg-[var(--accent)]/6 blur-[120px]"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--bg-card)]/60 px-4 py-2 text-sm text-[var(--text-muted)] backdrop-blur-sm">
        <span class="h-2 w-2 rounded-full bg-[var(--accent)] animate-pulse" aria-hidden="true"></span>
        Free 30-Min Session
      </div>

      <h1
        id="demo-hero-heading"
        class="font-heading text-4xl sm:text-5xl font-bold text-[var(--text)] mb-6"
      >
        See Our Products in Action
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-[var(--text-dim)] leading-relaxed">
        30-minute live walkthrough, no commitment, no sales pressure. Just a clear look at what the product can do for your business.
      </p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       WHAT TO EXPECT — 3 STEPS
  ════════════════════════════════════════════════════════════════════════ -->
  <section aria-labelledby="demo-steps-heading" class="bg-[var(--bg-card)] border-y border-[var(--border)] py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 id="demo-steps-heading" class="sr-only">How the demo works</h2>
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-center gap-4 sm:gap-0">
        {steps.map((s, i) => (
          <>
            <div class="flex items-start sm:items-center gap-4 sm:flex-col sm:text-center sm:max-w-[180px]">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[var(--accent)] font-bold text-[#0A0E1A] text-sm">
                {s.step}
              </div>
              <div>
                <p class="font-semibold text-[var(--text)] text-sm">{s.title}</p>
                <p class="text-xs text-[var(--text-muted)] mt-0.5 leading-relaxed">{s.desc}</p>
              </div>
            </div>
            {i < steps.length - 1 && (
              <div class="hidden sm:block h-px w-16 bg-[var(--border)] mx-4 shrink-0" aria-hidden="true"></div>
            )}
          </>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       DEMO REQUEST FORM
  ════════════════════════════════════════════════════════════════════════ -->
  <section aria-labelledby="demo-form-heading" class="bg-[var(--bg)] py-16 md:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
      <h2 id="demo-form-heading" class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] mb-2 text-center">
        Book Your Free Demo
      </h2>
      <p class="text-center text-[var(--text-dim)] mb-8">
        Fill in the form and we'll confirm your session within 4 business hours.
      </p>

      <!-- TODO: RequestDemoForm island (Step 3) -->
      <form action="/api/demo-request" method="POST" class="space-y-6">

        <fieldset>
          <legend class="font-semibold text-[var(--text)] mb-3">Which product would you like to see? <span aria-hidden="true">*</span></legend>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <label class="flex items-center gap-3 p-4 rounded-xl border border-[var(--border)] cursor-pointer has-[:checked]:border-[var(--accent)] has-[:checked]:bg-[var(--accent)]/5 transition-colors">
              <input type="radio" name="product" value="real-estate-portal" required class="accent-[var(--accent)]" />
              <span class="text-sm font-medium text-[var(--text)]">Real Estate Portal</span>
            </label>
            <label class="flex items-center gap-3 p-4 rounded-xl border border-[var(--border)] cursor-pointer has-[:checked]:border-[var(--accent)] has-[:checked]:bg-[var(--accent)]/5 transition-colors">
              <input type="radio" name="product" value="medical-conference-portal" class="accent-[var(--accent)]" />
              <span class="text-sm font-medium text-[var(--text)]">Medical Conference Portal</span>
            </label>
            <label class="flex items-center gap-3 p-4 rounded-xl border border-[var(--border)] cursor-pointer has-[:checked]:border-[var(--accent)] has-[:checked]:bg-[var(--accent)]/5 transition-colors">
              <input type="radio" name="product" value="ima-society-portal" class="accent-[var(--accent)]" />
              <span class="text-sm font-medium text-[var(--text)]">IMA Society Portal</span>
            </label>
            <label class="flex items-center gap-3 p-4 rounded-xl border border-[var(--border)] cursor-pointer has-[:checked]:border-[var(--accent)] has-[:checked]:bg-[var(--accent)]/5 transition-colors">
              <input type="radio" name="product" value="resort-management-system" class="accent-[var(--accent)]" />
              <span class="text-sm font-medium text-[var(--text)]">Resort Management System</span>
            </label>
          </div>
        </fieldset>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="demo-name" class="block text-sm font-medium text-[var(--text)] mb-1">Full Name <span aria-hidden="true">*</span></label>
            <input
              id="demo-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg)] px-4 py-2.5 text-sm text-[var(--text)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)]"
            />
          </div>
          <div>
            <label for="demo-email" class="block text-sm font-medium text-[var(--text)] mb-1">Email <span aria-hidden="true">*</span></label>
            <input
              id="demo-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg)] px-4 py-2.5 text-sm text-[var(--text)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)]"
            />
          </div>
          <div>
            <label for="demo-phone" class="block text-sm font-medium text-[var(--text)] mb-1">Phone</label>
            <input
              id="demo-phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg)] px-4 py-2.5 text-sm text-[var(--text)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)]"
            />
          </div>
          <div>
            <label for="demo-company" class="block text-sm font-medium text-[var(--text)] mb-1">Company</label>
            <input
              id="demo-company"
              name="company"
              type="text"
              autocomplete="organization"
              class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg)] px-4 py-2.5 text-sm text-[var(--text)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)]"
            />
          </div>
        </div>

        <div>
          <label for="demo-notes" class="block text-sm font-medium text-[var(--text)] mb-1">Notes / Questions</label>
          <textarea
            id="demo-notes"
            name="notes"
            rows={3}
            class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg)] px-4 py-2.5 text-sm text-[var(--text)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-3 text-base font-semibold text-[#0A0E1A] hover:opacity-90 transition-opacity w-full justify-center"
        >
          Request My Demo →
        </button>
      </form>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       RESPONSE PROMISE
  ════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[var(--bg-card)] border-t border-[var(--border)] py-10">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)]" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <p class="text-[var(--text-dim)] text-sm">
          <strong class="text-[var(--text)]">Response promise:</strong> We confirm your demo within 4 business hours.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
