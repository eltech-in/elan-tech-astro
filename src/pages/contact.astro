---
import BaseLayout from "../layouts/BaseLayout.astro";
import { breadcrumbSchema, localBusinessSchema } from "../utils/schema";

const schema = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Contact", url: "/contact" },
  ]),
  localBusinessSchema("Nagpur"),
];

const inputClass =
  "w-full rounded-lg border border-[var(--border)] bg-[var(--bg)] px-4 py-2.5 text-sm text-[var(--text)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)]";
const labelClass = "block text-sm font-medium text-[var(--text)] mb-1.5";
---

<BaseLayout
  title="Contact eLan Technology — Get in Touch"
  description="Get in touch with the eLan Technology team. We're based in Nagpur and work with clients globally. WhatsApp, email, or fill out our contact form."
  schema={schema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-[var(--bg)] py-20 sm:py-28">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p
        class="text-sm font-semibold uppercase tracking-widest text-[var(--accent)] mb-4"
      >
        Get in Touch
      </p>
      <h1
        class="font-heading text-4xl sm:text-5xl font-bold text-[var(--text)] leading-tight"
      >
        Let's Start a Conversation
      </h1>
      <p
        class="mt-6 max-w-2xl mx-auto text-lg text-[var(--text-dim)] leading-relaxed"
      >
        Whether you have a project in mind, a question about our services, or
        just want to say hello — we'd love to hear from you. We respond within 4
        business hours.
      </p>
    </div>
  </section>

  <!-- Contact grid -->
  <section
    class="py-16 md:py-20 border-t border-[var(--border)]"
    aria-labelledby="contact-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 id="contact-heading" class="sr-only">Contact Form and Details</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact form -->
        <div>
          <h2 class="font-heading text-2xl font-bold text-[var(--text)] mb-6">
            Send Us a Message
          </h2>
          <!-- TODO: ContactForm island (Step 3) -->
          <form
            action="/api/contact"
            method="POST"
            class="space-y-5"
            novalidate
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class={labelClass}
                  >Full Name <span class="text-red-400" aria-hidden="true"
                    >*</span
                  ></label
                >
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  autocomplete="name"
                  placeholder="Your full name"
                  class={inputClass}
                />
              </div>
              <div>
                <label for="email" class={labelClass}
                  >Email <span class="text-red-400" aria-hidden="true">*</span
                  ></label
                >
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                  placeholder="you@company.com"
                  class={inputClass}
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="phone" class={labelClass}>Phone</label>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  autocomplete="tel"
                  placeholder="+91 98765 43210"
                  class={inputClass}
                />
              </div>
              <div>
                <label for="company" class={labelClass}>Company</label>
                <input
                  id="company"
                  name="company"
                  type="text"
                  autocomplete="organization"
                  placeholder="Your company name"
                  class={inputClass}
                />
              </div>
            </div>

            <div>
              <label for="service" class={labelClass}>Service Needed</label>
              <select id="service" name="service" class={inputClass}>
                <option value="">Select a service…</option>
                <option value="website-design">Website Design</option>
                <option value="web-development">Web Development</option>
                <option value="ecommerce">eCommerce</option>
                <option value="digital-marketing">Digital Marketing</option>
                <option value="mobile-app">Mobile App Development</option>
                <option value="branding">Branding</option>
                <option value="api-integration">API Integration</option>
                <option value="maintenance">Maintenance &amp; Security</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>

            <div>
              <label for="message" class={labelClass}
                >Message <span class="text-red-400" aria-hidden="true">*</span
                ></label
              >
              <textarea
                id="message"
                name="message"
                rows={5}
                required
                placeholder="Tell us about your project, goals, or any questions you have…"
                class={inputClass}></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-3 text-base font-semibold text-[#0A0E1A] hover:opacity-90 transition-opacity w-full justify-center sm:w-auto"
            >
              Send Message
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
                  points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
              >
            </button>
          </form>
        </div>

        <!-- Contact details -->
        <div>
          <h2 class="font-heading text-2xl font-bold text-[var(--text)] mb-6">
            Contact Details
          </h2>

          <div class="space-y-6">
            <!-- WhatsApp -->
            <div
              class="flex items-start gap-4 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-5"
            >
              <div
                class="w-10 h-10 rounded-xl bg-green-500/10 flex items-center justify-center flex-shrink-0"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#22c55e"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"
                  ></path></svg
                >
              </div>
              <div>
                <p class="font-semibold text-[var(--text)] mb-0.5">
                  WhatsApp (Fastest)
                </p>
                <a
                  href="https://wa.me/918788834630"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[var(--accent)] hover:underline font-medium"
                  >+91 87888 34630</a
                >
                <p class="text-xs text-[var(--text-muted)] mt-1">
                  Typically replies within 30 minutes
                </p>
              </div>
            </div>

            <!-- Email -->
            <div
              class="flex items-start gap-4 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-5"
            >
              <div
                class="w-10 h-10 rounded-xl bg-[var(--accent)]/10 flex items-center justify-center flex-shrink-0"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--accent)"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  ></path><polyline points="22,6 12,13 2,6"></polyline></svg
                >
              </div>
              <div>
                <p class="font-semibold text-[var(--text)] mb-0.5">Email</p>
                <a
                  href="mailto:info@elan-tech.net"
                  class="text-[var(--accent)] hover:underline font-medium"
                  >info@elan-tech.net</a
                >
                <p class="text-xs text-[var(--text-muted)] mt-1">
                  We reply within 4 business hours
                </p>
              </div>
            </div>

            <!-- Address -->
            <div
              class="flex items-start gap-4 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-5"
            >
              <div
                class="w-10 h-10 rounded-xl bg-[var(--accent)]/10 flex items-center justify-center flex-shrink-0"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--accent)"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"
                  ></path><circle cx="12" cy="10" r="3"></circle></svg
                >
              </div>
              <div>
                <p class="font-semibold text-[var(--text)] mb-0.5">
                  Office Address
                </p>
                <address
                  class="not-italic text-sm text-[var(--text-dim)] leading-relaxed"
                >
                  Basement Floor, PTG IT Park<br />
                  Plot No. 21, IT Park Rd, Gayatri Nagar<br />
                  Nagpur, Maharashtra — 440022<br />
                  India
                </address>
                <a
                  href="https://maps.google.com/?q=PTG+IT+Park+Nagpur"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block mt-2 text-xs text-[var(--accent)] hover:underline"
                >
                  View on Google Maps →
                </a>
              </div>
            </div>

            <!-- Business hours -->
            <div
              class="flex items-start gap-4 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-5"
            >
              <div
                class="w-10 h-10 rounded-xl bg-[var(--accent)]/10 flex items-center justify-center flex-shrink-0"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--accent)"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><circle cx="12" cy="12" r="10"></circle><polyline
                    points="12 6 12 12 16 14"></polyline></svg
                >
              </div>
              <div>
                <p class="font-semibold text-[var(--text)] mb-0.5">
                  Business Hours
                </p>
                <p class="text-sm text-[var(--text-dim)]">Monday – Saturday</p>
                <p class="text-sm font-medium text-[var(--text)]">
                  10:00 AM – 7:00 PM IST
                </p>
                <p class="text-xs text-[var(--text-muted)] mt-1">
                  Closed on Sundays and public holidays
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Other ways to reach us -->
  <section
    class="py-16 md:py-20 bg-[var(--bg-card)] border-t border-[var(--border)]"
    aria-labelledby="other-contact-heading"
  >
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2
        id="other-contact-heading"
        class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] mb-8 text-center"
      >
        Other Ways to Reach Us
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <!-- WhatsApp card -->
        <a
          href="https://wa.me/+918788834630"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl border border-[var(--border)] bg-[var(--bg)] p-6 text-center hover:border-green-500 transition-colors group"
        >
          <div
            class="w-12 h-12 rounded-2xl bg-green-500/10 flex items-center justify-center mx-auto mb-4"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#22c55e"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"
              ></path></svg
            >
          </div>
          <h3 class="font-semibold text-[var(--text)] mb-1">WhatsApp</h3>
          <p class="text-xs text-[var(--text-muted)]">
            Fastest response · usually under 30 min
          </p>
        </a>

        <!-- Email card -->
        <a
          href="mailto:info@elan-tech.net"
          class="rounded-2xl border border-[var(--border)] bg-[var(--bg)] p-6 text-center hover:border-[var(--accent)] transition-colors group"
        >
          <div
            class="w-12 h-12 rounded-2xl bg-[var(--accent)]/10 flex items-center justify-center mx-auto mb-4"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--accent)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><polyline points="22,6 12,13 2,6"></polyline></svg
            >
          </div>
          <h3 class="font-semibold text-[var(--text)] mb-1">Email</h3>
          <p class="text-xs text-[var(--text-muted)]">
            info@elan-tech.net · within 2 business days
          </p>
        </a>

        <!-- Schedule a call card -->
        <a
          href="/schedule-consultation"
          class="rounded-2xl border border-[var(--border)] bg-[var(--bg)] p-6 text-center hover:border-[var(--accent)] transition-colors group"
        >
          <div
            class="w-12 h-12 rounded-2xl bg-[var(--accent)]/10 flex items-center justify-center mx-auto mb-4"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--accent)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"
              ></rect><line x1="16" y1="2" x2="16" y2="6"></line><line
                x1="8"
                y1="2"
                x2="8"
                y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg
            >
          </div>
          <h3 class="font-semibold text-[var(--text)] mb-1">Schedule a Call</h3>
          <p class="text-xs text-[var(--text-muted)]">
            Book a free 30-minute discovery call
          </p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
