---
import InternationalLayout from '../layouts/InternationalLayout.astro';
import InternationalWhyOutsource from '../components/international/InternationalWhyOutsource.astro';
import InternationalCostComparison from '../components/international/InternationalCostComparison.astro';
import InternationalServices from '../components/international/InternationalServices.astro';
import InternationalFAQ from '../components/international/InternationalFAQ.astro';
import InternationalContact from '../components/international/InternationalContact.astro';
import { getCountryBySlug } from '../data/countries';

const country = getCountryBySlug('canada')!;
---

<InternationalLayout country={country}>
  <InternationalWhyOutsource country={country} />
  <InternationalCostComparison country={country} />
  <InternationalServices country={country} />
  <InternationalFAQ country={country} />
  <InternationalContact country={country} />
</InternationalLayout>
