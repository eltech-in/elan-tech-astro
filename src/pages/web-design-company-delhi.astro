---
// TODO: Full city page content (Step 8 expansion)
import CityLayout from '../layouts/CityLayout.astro';
import { localBusinessSchema, breadcrumbSchema } from '../utils/schema';

const schema = [
  localBusinessSchema('Delhi', {
    url: 'https://elan-tech.net/web-design-company-delhi',
    description: 'Professional web design & digital marketing for Delhi NCR businesses. Custom websites, SEO, and eCommerce. WCAG compliant.',
    geo: { latitude: 28.6139, longitude: 77.2090 },
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services' },
    { name: 'Web Design Company Delhi NCR', url: '/web-design-company-delhi' },
  ]),
];
---

<CityLayout
  title="Web Design Company in Delhi NCR — eLan Technology"
  description="Professional web design & digital marketing for Delhi NCR businesses. Custom websites, SEO, and eCommerce. WCAG compliant. Get a free website audit."
  city="Delhi NCR"
  state="Delhi"
  heroHeading="Web Design Company in Delhi NCR"
  heroSubtext="Custom websites, SEO & digital marketing for Delhi and NCR businesses. Trusted pan-India since 2002."
  schema={schema}
>

  <section class="py-16 text-center px-4">
    <div class="mx-auto max-w-2xl">
      <h2 class="font-heading text-2xl font-bold text-[var(--text)] mb-4">
        Web Design Services in Delhi NCR — Coming Soon
      </h2>
      <p class="text-[var(--text-dim)] mb-6">
        We are expanding our local presence to Delhi NCR. In the meantime, we serve Delhi businesses
        remotely with the same quality and dedication as our Nagpur clients.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-3 font-semibold text-[#0A0E1A] hover:opacity-90 transition-opacity">
        Contact Us Today
      </a>
    </div>
  </section>

</CityLayout>
