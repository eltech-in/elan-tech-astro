---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { services } from '../../data/services';
import { cities } from '../../data/cities';
import { serviceSchema, faqSchema, breadcrumbSchema } from '../../utils/schema';

const service = services.find((s) => s.slug === 'branding')!;

const serviceFaqs = [
  {
    question: 'What do I receive at the end of a branding project?',
    answer: 'You receive a comprehensive brand kit delivered as a structured folder: logo files in all required formats (SVG, PNG transparent, PDF, and AI/EPS source files), a brand guidelines PDF covering logo usage rules, colour palette with HEX/RGB/CMYK/Pantone values, typography guidelines with font files, iconography, and usage examples. Everything you need to maintain brand consistency across print and digital.',
  },
  {
    question: 'How many logo concepts do you present?',
    answer: 'We present 3 initial logo concepts, each representing a distinctly different creative direction. After you select a preferred direction, we include up to 3 rounds of revisions to refine it to your satisfaction. Additional revision rounds are available at an hourly rate. We do not produce dozens of concepts — quality and strategic thinking over quantity.',
  },
  {
    question: 'Can you rebrand an existing business?',
    answer: "Yes — rebranding is a large part of our branding practice. We begin with a strategic discovery phase: understanding why the current brand isn't working, auditing brand perception, reviewing competitor positioning, and interviewing stakeholders. From there, we develop a brand strategy before touching a single logo — ensuring the visual identity is built on the right strategic foundation.",
  },
  {
    question: 'Do you handle print materials?',
    answer: 'Yes. Once your brand identity is established, we design all supporting print collateral: business cards, letterheads, with-compliments slips, brochures, presentation templates, pull-up banners, signage, packaging, and more. Every piece is designed to the brand guidelines and supplied in print-ready CMYK PDF format at the correct bleed and resolution.',
  },
  {
    question: 'How long does a branding project take?',
    answer: 'A standalone logo design project takes approximately 2–4 weeks. A full brand identity system — including logo, colour palette, typography, brand guidelines, and basic collateral — typically takes 4–8 weeks depending on the number of revision rounds and stakeholder decision-making speed. Rebranding projects with a strategic discovery phase may take 6–10 weeks.',
  },
];

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services' },
  { name: service.title, href: `/services/${service.slug}` },
];

const schemaBreadcrumbs = breadcrumbs.map((b) => ({ name: b.name, url: b.href }));

const schemas = [
  serviceSchema(service.title, service.description, `/services/${service.slug}`),
  faqSchema(serviceFaqs),
  breadcrumbSchema(schemaBreadcrumbs),
];

const featuredCities = cities.filter((c) => c.isFeatured).slice(0, 6);

const deliverables = [
  { format: 'SVG', desc: 'Scalable vector — for web, apps, and digital use' },
  { format: 'PNG (transparent)', desc: 'For digital and web use at any background colour' },
  { format: 'PDF', desc: 'Print-quality vector for professional printing' },
  { format: 'AI / EPS', desc: 'Source files for further design work' },
  { format: 'Brand Guidelines PDF', desc: 'Complete usage rules and standards document' },
  { format: 'Colour Palette', desc: 'HEX, RGB, CMYK, and Pantone values' },
  { format: 'Typography Guide', desc: 'Fonts, weights, sizes, and usage hierarchy' },
  { format: 'Icon System', desc: 'Supporting iconography and graphic elements' },
];
---
<ServiceLayout
  title={`${service.title} Services | eLan Technology`}
  description={service.description}
  breadcrumbs={breadcrumbs}
  schema={schemas}
>

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="relative mb-12 overflow-hidden rounded-2xl bg-gradient-to-br from-purple-500/10 via-[var(--bg-card)] to-[var(--bg-card)] p-8 md:p-12 border border-[var(--border)]">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest" style="color: #A855F7;">{service.tagline}</p>
        <h1 class="font-heading text-3xl font-bold leading-tight text-[var(--text)] md:text-4xl lg:text-5xl">
          {service.title} Services — eLan Technology
        </h1>
        <p class="mt-4 text-base text-[var(--text-muted)] md:text-lg">
          {service.description} Your brand is the most valuable asset in your business — it shapes how customers perceive, trust, and remember you. We build brand identities with strategic purpose, ensuring every visual decision reinforces your positioning and creates a lasting emotional connection with your audience.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/schedule-consultation" class="inline-flex items-center rounded-lg px-5 py-2.5 text-sm font-semibold text-white shadow transition hover:opacity-90" style="background: #A855F7;">
            Get Free Consultation
          </a>
          <a href="/get-quote" class="inline-flex items-center rounded-lg border border-[var(--border)] px-5 py-2.5 text-sm font-semibold text-[var(--text)] transition hover:bg-[var(--bg)]">
            Get a Quote
          </a>
        </div>
      </div>
      <ul class="space-y-3">
        {service.features.map((f) => (
          <li class="flex items-center gap-3 rounded-lg bg-[var(--bg)] px-4 py-3 border border-[var(--border)] text-sm font-medium text-[var(--text)]">
            <span class="text-green-400 font-bold">✓</span> {f}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── WHAT'S INCLUDED ───────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-2">What's Included in Our {service.shortTitle} Services</h2>
    <p class="text-[var(--text-muted)] mb-8">From logo design to full brand identity systems — we build every element your business needs to present itself consistently and professionally.</p>
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
      {[
        { icon: '✏️', name: 'Logo Design', desc: 'We design distinctive, versatile logos that work at every size — from app icons to billboard signage. Our design process begins with brand strategy and competitive research, ensuring your logo communicates the right message to the right audience.' },
        { icon: '🎨', name: 'Brand Identity Systems', desc: 'Beyond the logo — we design the complete visual language of your brand. Colour palettes, typographic systems, iconography, illustration styles, photography direction, and graphic motifs that create instant recognition across every platform.' },
        { icon: '📋', name: 'Brand Style Guides', desc: 'A comprehensive brand guidelines document that ensures every designer, printer, and agency that touches your brand uses it correctly. Covers logo usage, spacing rules, colour codes, font specifications, tone of voice, and real-world application examples.' },
        { icon: '🔄', name: 'Rebranding', desc: 'When your existing brand no longer reflects who you are or who you serve, a strategic rebrand can transform perception. We manage the entire rebranding process — from stakeholder interviews and strategy to new identity design and rollout planning.' },
        { icon: '🖨️', name: 'Marketing Collateral', desc: 'Business cards, letterheads, envelopes, brochures, presentation templates, pull-up banners, and digital assets — all designed to the same brand standard and supplied in both digital and print-ready formats.' },
        { icon: '🧭', name: 'Brand Strategy', desc: 'Great visual design without strategy is just decoration. We develop brand positioning statements, value propositions, audience personas, brand voice guidelines, and competitive differentiation frameworks that inform every creative decision.' },
        { icon: '🌐', name: 'Digital Brand Assets', desc: 'Social media profile images and banner templates, email signature designs, presentation templates, digital ad templates, and web UI component guidelines — ensuring your brand is as strong online as it is in print.' },
        { icon: '📦', name: 'Packaging Design', desc: 'For product businesses, packaging is a critical brand touchpoint. We design retail-ready packaging that commands shelf attention, communicates product benefits, and reinforces brand identity — with print-ready artwork supplied to exacting specifications.' },
      ].map(({ icon, name, desc }) => (
        <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-5">
          <div class="mb-3 inline-flex h-11 w-11 items-center justify-center rounded-xl text-xl" style="background: #A855F720;">{icon}</div>
          <h3 class="font-heading text-base font-semibold text-[var(--text)] mb-2">{name}</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── WHAT MAKES A STRONG BRAND ────────────────────────────────────────── -->
  <section class="mb-16 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-8 md:p-10">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-3">What Makes a Strong Brand Identity?</h2>
    <p class="text-[var(--text-muted)] mb-8">The world's most recognisable brands share the same fundamental qualities. Here is what we build into every brand identity we create:</p>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { icon: '🎯', title: 'Distinctiveness', desc: 'Your brand should be unmistakable in your industry. We research competitors extensively before beginning design to ensure your identity occupies a unique visual space that customers associate exclusively with your business.' },
        { icon: '⚖️', title: 'Consistency', desc: 'A brand is only as strong as its consistency. We build comprehensive style guides that enable your team, agencies, and vendors to apply your brand correctly across every medium — from social posts to signage.' },
        { icon: '💡', title: 'Relevance', desc: 'Your brand must resonate with the specific audience you serve. We ground every creative decision in audience research, ensuring your visual identity speaks directly to your customers\' values, aspirations, and expectations.' },
        { icon: '🔄', title: 'Flexibility', desc: 'Great brands work at any scale and in any context — a 16×16 pixel favicon, a printed T-shirt, a building facade. We design identities with this versatility baked in from the start.' },
        { icon: '📖', title: 'Storytelling', desc: "Every element of your brand should contribute to a coherent story about who you are, what you stand for, and why customers should choose you. Brand identity is visual communication at its most strategic." },
        { icon: '⏳', title: 'Longevity', desc: 'We design for endurance, not trend cycles. A well-designed brand identity should remain relevant and distinctive for a decade or more — evolving gently rather than requiring expensive periodic reinventions.' },
      ].map(({ icon, title, desc }) => (
        <div class="rounded-xl bg-[var(--bg)] border border-[var(--border)] p-5">
          <div class="mb-2 text-2xl">{icon}</div>
          <h3 class="font-heading text-sm font-semibold text-[var(--text)] mb-2">{title}</h3>
          <p class="text-sm text-[var(--text-muted)]">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── DELIVERABLES ───────────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-2">What You'll Receive</h2>
    <p class="text-[var(--text-muted)] mb-6">A full branding engagement delivers everything you need to maintain and grow your brand consistently — with all files organised and ready to use.</p>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      {deliverables.map(({ format, desc }) => (
        <div class="flex items-center gap-3 rounded-lg border border-[var(--border)] bg-[var(--bg-card)] px-4 py-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-xs font-bold text-white" style="background: #A855F7;">{format.slice(0, 3)}</span>
          <div>
            <p class="text-sm font-semibold text-[var(--text)]">{format}</p>
            <p class="text-xs text-[var(--text-muted)]">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── OUR PROCESS ────────────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-2">Our {service.shortTitle} Process</h2>
    <p class="text-[var(--text-muted)] mb-8">Strategy-first branding that results in identities built to last — not visual decoration designed in isolation.</p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { n: '1', title: 'Discovery & Strategy', desc: 'Brand discovery workshop covering business goals, audience research, competitive landscape, brand values, personality, and positioning. We develop a creative brief that guides every design decision.' },
        { n: '2', title: 'Design & Planning', desc: 'We present 3 distinct logo concepts developed from the brief, each with full rationale. Mood boards, colour explorations, and typographic pairings accompany each direction to convey the full brand system potential.' },
        { n: '3', title: 'Development & Refinement', desc: 'You choose a direction and we refine it through up to 3 rounds of feedback. Once the logo is approved, we build out the full brand system — colours, typography, supporting elements, and collateral designs.' },
        { n: '4', title: 'Delivery & Handover', desc: 'All files are organised in a structured delivery folder with a comprehensive brand guidelines PDF. We walk you through the handover, answer questions, and provide guidance on consistent brand application going forward.' },
      ].map(({ n, title, desc }) => (
        <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-5">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-full font-heading text-sm font-bold text-white" style="background: #A855F7;">{n}</div>
          <h3 class="font-heading text-sm font-semibold text-[var(--text)] mb-2">{title}</h3>
          <p class="text-sm text-[var(--text-muted)]">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-8">Frequently Asked Questions</h2>
    <div class="divide-y divide-[var(--border)] rounded-xl border border-[var(--border)] overflow-hidden">
      {serviceFaqs.map(({ question, answer }) => (
        <details class="bg-[var(--bg-card)] py-0">
          <summary class="cursor-pointer font-medium text-[var(--text)] flex items-center justify-between px-6 py-4 hover:bg-[var(--bg)] transition-colors list-none">
            <span>{question}</span>
            <span class="ml-4 shrink-0 text-[var(--text-muted)] text-lg">+</span>
          </summary>
          <p class="px-6 pb-5 pt-1 text-sm text-[var(--text-muted)] leading-relaxed">{answer}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ── CITY LINKS ─────────────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-xl font-bold text-[var(--text)] md:text-2xl mb-2">Branding Services Across India</h2>
    <p class="text-sm text-[var(--text-muted)] mb-6">We create brand identities for businesses in Nagpur, Raipur, Mumbai, Pune, Hyderabad, and Delhi — with international clients across the USA, UAE, UK, Australia, and Canada.</p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {featuredCities.map((city) => (
        <a
          href={city.hasLandingPage ? `/web-design-company-${city.slug}` : `/services/branding`}
          class="rounded-lg border border-[var(--border)] bg-[var(--bg-card)] px-4 py-3 hover:border-purple-500/50 transition-colors"
        >
          <p class="font-medium text-sm text-[var(--text)]">{city.name}</p>
          <p class="text-xs text-[var(--text-muted)] mt-0.5">Services available</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ── DOUBLE CTA ─────────────────────────────────────────────────────────── -->
  <section class="grid gap-5 md:grid-cols-2 mb-4">
    <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-7 flex flex-col">
      <h3 class="font-heading text-xl font-bold text-[var(--text)] mb-2">Ready to Get Started?</h3>
      <p class="text-sm text-[var(--text-muted)] mb-5 flex-1">Share your existing brand materials with us for a free brand audit. We'll identify gaps, inconsistencies, and opportunities — and show you what a refreshed identity could look like for your business. * Conditions apply.</p>
      <a href="/free-website-audit" class="inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition hover:opacity-90" style="background: #A855F7;">
        Get Free Audit
      </a>
    </div>
    <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-7 flex flex-col">
      <h3 class="font-heading text-xl font-bold text-[var(--text)] mb-2">Have Questions?</h3>
      <p class="text-sm text-[var(--text-muted)] mb-5 flex-1">Wondering whether you need a full rebrand or just a logo refresh? Speak to one of our brand strategists and get a clear, honest assessment of where your brand stands today and what it needs to grow.</p>
      <a href="/schedule-consultation" class="inline-flex items-center justify-center rounded-lg border border-[var(--border)] px-5 py-2.5 text-sm font-semibold text-[var(--text)] transition hover:bg-[var(--bg)]">
        Schedule a Call
      </a>
    </div>
  </section>

</ServiceLayout>
