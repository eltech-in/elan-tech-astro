---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { services } from '../../data/services';
import { cities } from '../../data/cities';
import { serviceSchema, faqSchema, breadcrumbSchema } from '../../utils/schema';

const service = services.find((s) => s.slug === 'digital-marketing')!;

const serviceFaqs = [
  {
    question: 'How long before I see SEO results?',
    answer: 'SEO is a medium-to-long-term investment. Most clients start seeing measurable improvements in organic rankings and traffic within 3–6 months of sustained work. Competitive industries with established competitors may take 6–12 months for significant results. We set realistic expectations during onboarding and provide monthly reports so you can track progress at every stage.',
  },
  {
    question: 'Do you manage Google Ads campaigns?',
    answer: 'Yes. Our certified Google Ads team manages Search, Display, Performance Max, Shopping, and YouTube campaigns. We handle everything from keyword research and ad copywriting to bid management, audience targeting, A/B testing, and conversion tracking setup. Monthly reports include spend, impressions, clicks, conversions, and ROAS.',
  },
  {
    question: "What's included in an SEO audit?",
    answer: "Our SEO audit covers four pillars: technical SEO (crawlability, site speed, Core Web Vitals, mobile-friendliness, structured data), on-page SEO (title tags, meta descriptions, heading structure, content gaps, keyword targeting), backlink analysis (quality, toxicity, opportunities), and competitive analysis (what your top competitors rank for and how). You receive a prioritised action plan, not just a report.",
  },
  {
    question: 'Can you help with social media marketing?',
    answer: 'Yes. We manage organic social media presence and paid social advertising across Facebook, Instagram, LinkedIn, and YouTube. Our social media services include content strategy, creative production (graphics and short-form video), community management, influencer outreach, and paid campaign management with detailed performance reporting.',
  },
  {
    question: 'Do you provide monthly reports?',
    answer: 'Yes — detailed monthly reports are standard for all retainer clients. Reports cover organic keyword rankings, organic traffic, paid campaign performance (spend, conversions, ROAS), backlink growth, technical health changes, and recommendations for the next month. We also schedule a monthly call to walk through results and discuss strategy adjustments.',
  },
];

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services' },
  { name: service.title, href: `/services/${service.slug}` },
];

const schemaBreadcrumbs = breadcrumbs.map((b) => ({ name: b.name, url: b.href }));

const schemas = [
  serviceSchema(service.title, service.description, `/services/${service.slug}`),
  faqSchema(serviceFaqs),
  breadcrumbSchema(schemaBreadcrumbs),
];

const featuredCities = cities.filter((c) => c.isFeatured).slice(0, 6);
---
<ServiceLayout
  title={`${service.title} Services | eLan Technology`}
  description={service.description}
  breadcrumbs={breadcrumbs}
  schema={schemas}
>

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="relative mb-12 overflow-hidden rounded-2xl bg-gradient-to-br from-emerald-500/10 via-[var(--bg-card)] to-[var(--bg-card)] p-8 md:p-12 border border-[var(--border)]">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest" style="color: #00E5A0;">{service.tagline}</p>
        <h1 class="font-heading text-3xl font-bold leading-tight text-[var(--text)] md:text-4xl lg:text-5xl">
          {service.title} Services — eLan Technology
        </h1>
        <p class="mt-4 text-base text-[var(--text-muted)] md:text-lg">
          {service.description} We combine deep technical SEO expertise with creative content and performance advertising to build a sustainable pipeline of qualified leads. Every strategy is grounded in analytics — we measure what matters and continuously optimise to improve your return on investment.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/schedule-consultation" class="inline-flex items-center rounded-lg px-5 py-2.5 text-sm font-semibold text-white shadow transition hover:opacity-90" style="background: #00E5A0; color: #000;">
            Get Free Consultation
          </a>
          <a href="/get-quote" class="inline-flex items-center rounded-lg border border-[var(--border)] px-5 py-2.5 text-sm font-semibold text-[var(--text)] transition hover:bg-[var(--bg)]">
            Get a Quote
          </a>
        </div>
      </div>
      <ul class="space-y-3">
        {service.features.map((f) => (
          <li class="flex items-center gap-3 rounded-lg bg-[var(--bg)] px-4 py-3 border border-[var(--border)] text-sm font-medium text-[var(--text)]">
            <span class="text-green-400 font-bold">✓</span> {f}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── WHAT'S INCLUDED ───────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-2">What's Included in Our {service.shortTitle} Services</h2>
    <p class="text-[var(--text-muted)] mb-8">A full-stack digital marketing service covering every channel that drives qualified traffic and converts visitors into customers.</p>
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
      {[
        { icon: '🔍', name: 'Search Engine Optimisation (SEO)', desc: 'Technical SEO, on-page optimisation, content strategy, link building, and Core Web Vitals improvements. We target high-intent keywords that bring visitors ready to buy, not just browse. Monthly reporting tracks ranking improvements and organic traffic growth.' },
        { icon: '💰', name: 'Google Ads / PPC', desc: 'Certified Google Ads management across Search, Display, Shopping, and Performance Max campaigns. We conduct thorough keyword research, write compelling ad copy, set up conversion tracking, manage bids, and optimise continuously for maximum return on ad spend.' },
        { icon: '📱', name: 'Social Media Marketing', desc: 'Organic and paid social strategies across Facebook, Instagram, LinkedIn, and YouTube. We produce scroll-stopping creative, build engaged audiences, and run targeted paid campaigns that drive both brand awareness and measurable conversions.' },
        { icon: '✍️', name: 'Content Marketing', desc: 'Blog posts, landing pages, whitepapers, case studies, and video scripts that educate your audience and rank on search engines. Every piece of content is keyword-researched, strategically structured, and aligned with your sales funnel stage.' },
        { icon: '📧', name: 'Email Marketing', desc: 'Automated drip sequences, promotional campaigns, re-engagement flows, and abandoned cart emails built on Mailchimp, Klaviyo, or your existing platform. We write, design, and optimise emails to improve open rates, click-throughs, and revenue per recipient.' },
        { icon: '📍', name: 'Local SEO', desc: 'Google Business Profile optimisation, local citation building, review management, and hyperlocal keyword targeting. Essential for businesses serving specific cities or regions — we ensure you appear prominently in "near me" searches and Google Maps results.' },
        { icon: '📊', name: 'Analytics & Reporting', desc: 'GA4 setup, Google Tag Manager configuration, conversion goal tracking, custom dashboards, and monthly performance reports. We turn raw data into clear insights — showing you exactly which channels drive revenue and where to invest more.' },
        { icon: '🎯', name: 'Conversion Rate Optimisation', desc: 'A/B testing landing pages, analysing heatmaps and session recordings, improving form completion rates, and refining CTAs. We increase the percentage of your existing traffic that converts into leads or sales — getting more from the budget you already spend.' },
      ].map(({ icon, name, desc }) => (
        <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-5">
          <div class="mb-3 inline-flex h-11 w-11 items-center justify-center rounded-xl text-xl" style="background: #00E5A020;">{icon}</div>
          <h3 class="font-heading text-base font-semibold text-[var(--text)] mb-2">{name}</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── DATA-DRIVEN APPROACH ──────────────────────────────────────────────── -->
  <section class="mb-16 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-8 md:p-10">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-3">Our Data-Driven Marketing Approach</h2>
    <p class="text-[var(--text-muted)] mb-8">We do not guess. Every decision is backed by data — from keyword selection to budget allocation to creative testing. Our four-stage cycle drives continuous improvement.</p>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { icon: '📈', step: 'Analytics', desc: 'We instrument your entire digital presence — website, ads, social, and email — with comprehensive tracking. GA4, GTM, and platform-native analytics give us a complete picture of the customer journey, from first touch to conversion.' },
        { icon: '🧠', step: 'Strategy', desc: 'Data informs strategy. We identify your highest-value keywords, your most profitable customer segments, your best-performing content formats, and your biggest conversion bottlenecks — then build a prioritised plan around them.' },
        { icon: '🚀', step: 'Execute', desc: 'Our team of SEO specialists, PPC managers, content writers, and social media marketers execute the strategy across every channel simultaneously. Campaigns are launched with full tracking and baseline benchmarks in place.' },
        { icon: '🔄', step: 'Optimise', desc: 'After the first 30 days, we enter a continuous optimisation cycle — pausing underperformers, scaling winners, testing new creatives, and updating strategy based on fresh data. Your results compound over time.' },
      ].map(({ icon, step, desc }) => (
        <div class="rounded-xl bg-[var(--bg)] border border-[var(--border)] p-5">
          <div class="mb-3 text-2xl">{icon}</div>
          <h3 class="font-heading text-base font-semibold text-[var(--text)] mb-2">{step}</h3>
          <p class="text-sm text-[var(--text-muted)]">{desc}</p>
        </div>
      ))}
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-4">
      {[
        { label: 'KPI', value: 'Organic Traffic Growth' },
        { label: 'KPI', value: 'Keyword Rankings' },
        { label: 'KPI', value: 'Qualified Leads' },
        { label: 'KPI', value: 'ROAS (Return on Ad Spend)' },
      ].map(({ label, value }) => (
        <div class="rounded-lg bg-[var(--bg)] border border-[var(--border)] px-4 py-3 text-center">
          <p class="text-xs font-semibold uppercase tracking-wide text-[var(--text-muted)] mb-1">{label}</p>
          <p class="text-sm font-semibold text-[var(--text)]">{value}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── OUR PROCESS ────────────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-2">Our {service.shortTitle} Process</h2>
    <p class="text-[var(--text-muted)] mb-8">We onboard new clients carefully, building strong foundations before chasing quick wins — because sustainable growth takes structure.</p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { n: '1', title: 'Discovery & Audit', desc: 'We conduct a comprehensive audit of your current digital presence — website health, existing rankings, backlink profile, ad account history, social channels, and analytics setup. This establishes a clear baseline and priority list.' },
        { n: '2', title: 'Strategy & Planning', desc: 'We develop a 90-day marketing plan covering SEO targets, content calendar, ad campaigns, social strategy, and KPI benchmarks. You review and approve the plan before any campaign spending begins.' },
        { n: '3', title: 'Execution', desc: 'Our specialists execute across SEO, PPC, content, and social simultaneously. You receive weekly progress updates and have direct access to your account manager via WhatsApp or email throughout the engagement.' },
        { n: '4', title: 'Reporting & Optimisation', desc: 'Monthly reports cover every channel with clear visualisations and plain-English commentary. Monthly strategy calls review results, discuss market changes, and agree priorities for the next cycle.' },
      ].map(({ n, title, desc }) => (
        <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-5">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-full font-heading text-sm font-bold text-black" style="background: #00E5A0;">{n}</div>
          <h3 class="font-heading text-sm font-semibold text-[var(--text)] mb-2">{title}</h3>
          <p class="text-sm text-[var(--text-muted)]">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── TECHNOLOGIES ───────────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-4">Tools & Platforms We Use</h2>
    <div class="flex flex-wrap gap-3">
      {['Google Analytics 4', 'Google Search Console', 'Google Ads', 'Google Tag Manager', 'Semrush', 'Ahrefs', 'Meta Ads', 'LinkedIn Ads', 'Mailchimp', 'Klaviyo', 'Hotjar', 'Looker Studio', 'HubSpot', 'Screaming Frog', 'PageSpeed Insights'].map((tech) => (
        <span class="rounded-full border border-[var(--border)] bg-[var(--bg-card)] px-4 py-2 text-sm font-medium text-[var(--text-muted)] hover:border-emerald-500/50 hover:text-[var(--text)] transition-colors">
          {tech}
        </span>
      ))}
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-8">Frequently Asked Questions</h2>
    <div class="divide-y divide-[var(--border)] rounded-xl border border-[var(--border)] overflow-hidden">
      {serviceFaqs.map(({ question, answer }) => (
        <details class="bg-[var(--bg-card)] py-0">
          <summary class="cursor-pointer font-medium text-[var(--text)] flex items-center justify-between px-6 py-4 hover:bg-[var(--bg)] transition-colors list-none">
            <span>{question}</span>
            <span class="ml-4 shrink-0 text-[var(--text-muted)] text-lg">+</span>
          </summary>
          <p class="px-6 pb-5 pt-1 text-sm text-[var(--text-muted)] leading-relaxed">{answer}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ── CITY LINKS ─────────────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-xl font-bold text-[var(--text)] md:text-2xl mb-2">Digital Marketing Services Across India</h2>
    <p class="text-sm text-[var(--text-muted)] mb-6">We run SEO and digital marketing campaigns for businesses in Nagpur, Raipur, Mumbai, Pune, Hyderabad, Delhi, and across India — with deep knowledge of local search behaviour and competitive landscapes.</p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {featuredCities.map((city) => (
        <a
          href={city.hasLandingPage ? `/web-design-company-${city.slug}` : `/services/digital-marketing`}
          class="rounded-lg border border-[var(--border)] bg-[var(--bg-card)] px-4 py-3 hover:border-emerald-500/50 transition-colors"
        >
          <p class="font-medium text-sm text-[var(--text)]">{city.name}</p>
          <p class="text-xs text-[var(--text-muted)] mt-0.5">Services available</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ── DOUBLE CTA ─────────────────────────────────────────────────────────── -->
  <section class="grid gap-5 md:grid-cols-2 mb-4">
    <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-7 flex flex-col">
      <h3 class="font-heading text-xl font-bold text-[var(--text)] mb-2">Ready to Get Started?</h3>
      <p class="text-sm text-[var(--text-muted)] mb-5 flex-1">Get a free SEO and digital marketing audit. We'll show you exactly where your competitors are outranking you, what's holding your site back, and how to fix it — with no obligation to proceed. * Conditions apply.</p>
      <a href="/free-website-audit" class="inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-semibold text-black transition hover:opacity-90" style="background: #00E5A0;">
        Get Free Audit
      </a>
    </div>
    <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-7 flex flex-col">
      <h3 class="font-heading text-xl font-bold text-[var(--text)] mb-2">Have Questions?</h3>
      <p class="text-sm text-[var(--text-muted)] mb-5 flex-1">Not sure where to start with digital marketing? Schedule a free strategy call with one of our specialists and walk away with clarity on your priorities — regardless of whether you engage us.</p>
      <a href="/schedule-consultation" class="inline-flex items-center justify-center rounded-lg border border-[var(--border)] px-5 py-2.5 text-sm font-semibold text-[var(--text)] transition hover:bg-[var(--bg)]">
        Schedule a Call
      </a>
    </div>
  </section>

</ServiceLayout>
