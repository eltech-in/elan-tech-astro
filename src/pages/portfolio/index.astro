---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects, filterCategories } from '../../data/portfolio';
import { breadcrumbSchema } from '../../utils/schema';

const schema = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Portfolio', url: '/portfolio' },
]);
---

<BaseLayout
  title="Web Design & Development Portfolio — eLan Technology"
  description="Explore eLan Technology's portfolio of 1200+ projects: web design, web development, eCommerce, and enterprise portals for clients across India and internationally."
  schema={schema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-[var(--bg)] py-20 sm:py-28">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-[var(--accent)] mb-4">Our Work</p>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-[var(--text)] leading-tight">
        Our Work Speaks for Itself
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-lg text-[var(--text-dim)] leading-relaxed">
        {projects.length}+ projects delivered for clients across healthcare, education, hospitality, manufacturing, NGOs, and more — spanning India, USA, Canada, Australia, and the UAE.
      </p>
    </div>
  </section>

  <!-- Filter bar -->
  <section class="bg-[var(--bg)] py-8 border-b border-[var(--border)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- TODO: PortfolioFilter island (Step 3) -->
      <!-- Static fallback: show all projects -->
      <div class="flex flex-wrap gap-2 mb-2" role="group" aria-label="Filter by category">
        <span class="px-4 py-2 rounded-full bg-[var(--accent)] text-[#0A0E1A] text-sm font-medium cursor-default">All</span>
        {filterCategories.filter(c => c !== 'All').map((cat) => (
          <a href="#" class="px-4 py-2 rounded-full border border-[var(--border)] text-sm text-[var(--text-dim)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors">{cat}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects grid -->
  <section class="py-16 md:py-20" aria-labelledby="projects-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 id="projects-heading" class="sr-only">All Projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <article class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] overflow-hidden flex flex-col hover:border-[var(--accent)] transition-colors group">
            <!-- Project image -->
            <div class="relative aspect-video overflow-hidden bg-[var(--bg)]">
              <img
                src={project.image}
                alt={`${project.title} — ${project.category} project by eLan Technology`}
                width="640"
                height="360"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                onerror="this.style.display='none';this.parentElement.style.background='var(--bg-card)'"
              />
              <!-- Category badge -->
              <span
                class="absolute top-3 left-3 px-3 py-1 rounded-full text-xs font-semibold bg-[var(--bg)] border border-[var(--border)] text-[var(--text-dim)]"
                style={`border-color: ${project.accent}; color: ${project.accent}`}
              >
                {project.category}
              </span>
            </div>

            <div class="p-6 flex flex-col flex-1">
              <p class="text-xs text-[var(--text-muted)] mb-1">{project.client} · {project.industry}</p>
              <h3 class="font-heading text-lg font-semibold text-[var(--text)] mb-2 leading-snug">
                {project.title}
              </h3>
              <p class="text-sm text-[var(--text-dim)] leading-relaxed flex-1 line-clamp-3">
                {project.description}
              </p>

              <!-- Technologies -->
              <div class="flex flex-wrap gap-1.5 mt-4">
                {project.technologies.slice(0, 3).map((tech) => (
                  <span class="px-2 py-0.5 rounded text-xs bg-[var(--bg)] border border-[var(--border)] text-[var(--text-muted)]">
                    {tech}
                  </span>
                ))}
                {project.technologies.length > 3 && (
                  <span class="px-2 py-0.5 rounded text-xs bg-[var(--bg)] border border-[var(--border)] text-[var(--text-muted)]">
                    +{project.technologies.length - 3} more
                  </span>
                )}
              </div>

              <a
                href={`/portfolio/case-study/${project.slug}`}
                class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--accent)] hover:underline"
                aria-label={`View case study for ${project.title}`}
              >
                View Case Study
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-[var(--bg-card)] border-t border-[var(--border)]">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] mb-4">
        Have a project in mind?
      </h2>
      <p class="text-[var(--text-dim)] mb-8 text-lg">
        Let's talk about how we can help you build something remarkable.
      </p>
      <a
        href="/get-quote"
        class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-3 text-base font-semibold text-[#0A0E1A] hover:opacity-90 transition-opacity"
      >
        Get a Free Quote
      </a>
    </div>
  </section>
</BaseLayout>
