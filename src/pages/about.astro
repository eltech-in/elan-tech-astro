---
import BaseLayout from '../layouts/BaseLayout.astro';
import { organizationSchema, breadcrumbSchema } from '../utils/schema';

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'About', url: '/about' },
  ]),
];

const journey = [
  { year: '2002', title: 'The Beginning', desc: 'Founded in Nagpur with a mission to bring world-class web design to Central India. Started as a small studio focused on static websites for local businesses.' },
  { year: '2005–2008', title: 'Dynamic Web Era', desc: 'Expanded into dynamic web development with PHP and MySQL. Grew team to 10+ members and started serving businesses across Maharashtra.' },
  { year: '2009–2013', title: 'Going Mobile-First', desc: 'Embraced responsive, mobile-first design early. Landed our first international clients in the USA and UK. Started building custom CMS solutions.' },
  { year: '2014–2018', title: 'Full-Stack & Marketing', desc: 'Transitioned to full-stack JavaScript development. Launched digital marketing, SEO, and branding services. Built enterprise portals and School ERP systems.' },
  { year: '2019–2022', title: 'Global Expansion', desc: 'Launched IMA Society Portal serving thousands of members. Expanded client base to 25+ countries including USA, Canada, Australia, UAE, UK, Saudi Arabia, and Japan.' },
  { year: '2023–Present', title: 'AI-Powered & Accessible', desc: 'Embraced AI-powered development workflows. Became WCAG 2.1 AA and ADA compliance specialists. Migrated to modern frameworks like Astro and Next.js for blazing-fast performance.' },
];

const values = [
  { title: 'Accessibility First', desc: 'We build WCAG-compliant websites as standard — not as an add-on. Accessible design is better design. It improves usability for everyone, reduces legal risk, and ensures your digital presence is truly inclusive.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' },
  { title: 'Transparency', desc: 'Fixed-price projects with milestone-based billing. No hidden costs, no surprise invoices. You get a detailed breakdown before any work begins, and regular progress updates throughout.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>' },
  { title: 'Craftsmanship', desc: 'We target sub-2s load times and strong Core Web Vitals as baseline requirements. Every website we build is optimised for performance, security, and search engine visibility from day one.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>' },
  { title: 'Long-Term Partnership', desc: 'We are not a one-and-done agency. Our relationships with clients span years — we grow with you, evolve your digital presence, and stay available as a trusted technology partner long after launch day.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>' },
  { title: 'Continuous Learning', desc: 'We stay at the cutting edge — from performance-first frameworks like Astro and Next.js to AI-assisted tooling — so your website is built for the web of today and tomorrow, not the web of five years ago.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>' },
];
---

<BaseLayout
  title="About eLan Technology — Web Design Agency Since 2002"
  description="Learn about eLan Technology — a full-service web design and digital marketing agency founded in Nagpur in 2002. 24+ years, 500+ clients, 1500+ projects, 25+ countries."
  schema={schema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-[var(--bg)] py-20 sm:py-28">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-[var(--accent)] mb-4">Since 2002</p>
      <h1 class="font-heading text-4xl font-bold text-[var(--text)] sm:text-5xl lg:text-6xl leading-tight">
        About eLan Technology
      </h1>
      <p class="mt-6 max-w-3xl mx-auto text-lg text-[var(--text-dim)] leading-relaxed">
        From a small web design studio in Nagpur to a globally trusted digital agency — we've spent 24+ years designing, developing, and growing digital experiences for businesses across India and around the world.
      </p>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="bg-[var(--bg-card)] border-y border-[var(--border)] py-12" aria-label="Company statistics">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <dl class="grid grid-cols-2 gap-8 sm:grid-cols-5 text-center">
        <div>
          <dt class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wide">Experience</dt>
          <dd class="mt-2 text-4xl font-bold text-[var(--accent)]">24+</dd>
          <dd class="mt-1 text-sm text-[var(--text-dim)]">Years</dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wide">Happy Clients</dt>
          <dd class="mt-2 text-4xl font-bold text-[var(--accent)]">500+</dd>
          <dd class="mt-1 text-sm text-[var(--text-dim)]">Worldwide</dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wide">Projects</dt>
          <dd class="mt-2 text-4xl font-bold text-[var(--accent)]">1500+</dd>
          <dd class="mt-1 text-sm text-[var(--text-dim)]">Delivered</dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wide">Global Reach</dt>
          <dd class="mt-2 text-4xl font-bold text-[var(--accent)]">25+</dd>
          <dd class="mt-1 text-sm text-[var(--text-dim)]">Countries</dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wide">Team</dt>
          <dd class="mt-2 text-4xl font-bold text-[var(--accent)]">30+</dd>
          <dd class="mt-1 text-sm text-[var(--text-dim)]">Professionals</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-20 sm:py-24" aria-labelledby="mission-heading">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2">
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-8 md:p-10">
          <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--accent)]/10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
          </div>
          <h2 id="mission-heading" class="font-heading text-2xl font-bold text-[var(--text)] mb-4">Our Mission</h2>
          <p class="text-[var(--text-dim)] leading-relaxed">
            To empower businesses — from Nagpur startups to global enterprises — with websites and digital solutions that are beautiful, accessible, fast, and built to generate real results. We believe great technology should be within reach for every business, regardless of size or location.
          </p>
        </div>
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-8 md:p-10">
          <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--accent)]/10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h2 class="font-heading text-2xl font-bold text-[var(--text)] mb-4">Our Vision</h2>
          <p class="text-[var(--text-dim)] leading-relaxed">
            To be recognised as Central India's most trusted technology partner and a global leader in accessible, performance-driven web development. We envision a digital world where every website is inclusive, fast, and designed to deliver measurable business outcomes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="bg-[var(--bg-card)] py-20 sm:py-24" aria-labelledby="story-heading">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 id="story-heading" class="font-heading text-3xl font-bold text-[var(--text)] sm:text-4xl mb-8">
        Our Story
      </h2>
      <div class="space-y-6 text-[var(--text-dim)] leading-relaxed text-lg">
        <p>
          eLan Technology was founded in 2002 in Nagpur, Maharashtra — a time when having a website was still a novelty for most Indian businesses. Our founder, <strong class="text-[var(--text)]">Nishant Barde</strong>, saw an opportunity to help local businesses establish a credible online presence, and what started as a small web design studio quickly grew into something much larger.
        </p>
        <p>
          Over the years, we expanded our capabilities far beyond web design. We built complex web applications, enterprise portals, eCommerce platforms, and School ERP systems. We started serving clients not just in Nagpur, but across Raipur, Mumbai, Pune, and Delhi — and then internationally, with clients in the USA, Canada, Australia, UAE, UK, Saudi Arabia, and Japan.
        </p>
        <p>
          Through every phase of growth, we have held firm to one principle: <strong class="text-[var(--text)]">accessibility first</strong>. Every website we build is designed with WCAG compliance in mind, ensuring that the digital experiences we create are usable by everyone — regardless of ability, device, or connection speed.
        </p>
        <p>
          Today, with a team of <strong class="text-[var(--text)]">30+ skilled professionals</strong> and a combined <strong class="text-[var(--text)]">150+ years of industry experience</strong>, eLan Technology is a full-service digital agency with expertise spanning web design, development, eCommerce, digital marketing, mobile apps, and branding. We are proud to have partnered with hospitals, colleges, NGOs, manufacturing companies, resorts, media houses, and international organisations — and we bring the same dedication to every project, regardless of size.
        </p>
      </div>
    </div>
  </section>

  <!-- Journey Timeline -->
  <section class="py-20 sm:py-24" aria-labelledby="journey-heading">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 id="journey-heading" class="font-heading text-3xl font-bold text-[var(--text)] sm:text-4xl">
          Our Journey
        </h2>
        <p class="mt-4 text-[var(--text-dim)] max-w-2xl mx-auto">
          Over two decades of growth, innovation, and building lasting client partnerships.
        </p>
      </div>
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-[var(--border)] md:-translate-x-px" aria-hidden="true"></div>
        <div class="space-y-12">
          {journey.map((item, i) => (
            <div class={`relative flex flex-col md:flex-row md:items-start gap-4 md:gap-8 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              <!-- Dot -->
              <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-[var(--accent)] border-2 border-[var(--bg)] -translate-x-1.5 md:-translate-x-1.5 mt-1.5 z-10" aria-hidden="true"></div>
              <!-- Content -->
              <div class={`ml-10 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:text-right md:pr-8' : 'md:text-left md:pl-8'}`}>
                <span class="inline-block text-sm font-bold text-[var(--accent)] mb-2">{item.year}</span>
                <h3 class="font-heading text-xl font-semibold text-[var(--text)] mb-2">{item.title}</h3>
                <p class="text-[var(--text-dim)] text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="bg-[var(--bg-card)] py-20 sm:py-24" aria-labelledby="values-heading">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 id="values-heading" class="font-heading text-3xl font-bold text-[var(--text)] sm:text-4xl">
          Our Core Values
        </h2>
        <p class="mt-4 text-[var(--text-dim)] max-w-2xl mx-auto">
          These principles guide every decision we make — from how we design to how we communicate.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {values.map((v) => (
          <div class="rounded-2xl bg-[var(--bg)] border border-[var(--border)] p-8">
            <div class="w-12 h-12 rounded-xl bg-[var(--accent)]/10 flex items-center justify-center mb-5 text-[var(--accent)]" aria-hidden="true" set:html={v.icon} />
            <h3 class="font-heading text-xl font-semibold text-[var(--text)] mb-3">{v.title}</h3>
            <p class="text-[var(--text-dim)] leading-relaxed text-sm">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20 sm:py-24" aria-labelledby="team-heading">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 id="team-heading" class="font-heading text-3xl font-bold text-[var(--text)] sm:text-4xl">
          Leadership Team
        </h2>
        <p class="mt-4 text-[var(--text-dim)] max-w-2xl mx-auto">
          The people driving eLan Technology's vision and delivering results for clients worldwide.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <!-- Nishant Barde -->
        <div class="rounded-2xl bg-[var(--bg-card)] border border-[var(--border)] p-8 text-center">
          <div class="w-20 h-20 rounded-full bg-[var(--accent)]/20 flex items-center justify-center mx-auto mb-5" aria-hidden="true">
            <span class="text-2xl font-bold text-[var(--accent)]">NB</span>
          </div>
          <h3 class="font-heading text-xl font-semibold text-[var(--text)]">Nishant Barde</h3>
          <p class="text-[var(--accent)] text-sm font-medium mt-1">Founder & Director</p>
          <p class="mt-4 text-[var(--text-dim)] text-sm leading-relaxed">
            Visionary leader with 24+ years of technology entrepreneurship. Nishant founded eLan Technology in 2002 and has since grown it from a local studio into a globally trusted agency serving 500+ clients across 25+ countries.
          </p>
        </div>
        <!-- Abhishek Acharya -->
        <div class="rounded-2xl bg-[var(--bg-card)] border border-[var(--border)] p-8 text-center">
          <div class="w-20 h-20 rounded-full bg-[#A855F7]/20 flex items-center justify-center mx-auto mb-5" aria-hidden="true">
            <span class="text-2xl font-bold text-[#A855F7]">AA</span>
          </div>
          <h3 class="font-heading text-xl font-semibold text-[var(--text)]">Abhishek Acharya</h3>
          <p class="text-[var(--accent)] text-sm font-medium mt-1">Mentor & Training Lead</p>
          <p class="mt-4 text-[var(--text-dim)] text-sm leading-relaxed">
            Dedicated to guiding learners with practical knowledge and industry insights. Abhishek ensures our team stays sharp with the latest technologies and best practices through continuous training programmes.
          </p>
        </div>
      </div>
      <div class="mt-10 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-6 md:p-8 max-w-3xl mx-auto text-center">
        <p class="text-[var(--text-dim)]">
          Behind our leadership, a team of <strong class="text-[var(--text)]">30+ skilled professionals</strong> — designers, developers, SEO specialists, content strategists, and project managers — brings a combined <strong class="text-[var(--text)]">150+ years of industry experience</strong> to every project.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Businesses Choose eLan -->
  <section class="bg-[var(--bg-card)] py-20 sm:py-24" aria-labelledby="why-us-heading">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 id="why-us-heading" class="font-heading text-3xl font-bold text-[var(--text)] sm:text-4xl">
          Why Businesses Choose eLan
        </h2>
        <p class="mt-4 text-[var(--text-dim)] max-w-2xl mx-auto">
          Not all web agencies are created equal. Here is what sets eLan apart.
        </p>
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6" role="list">
        {[
          { title: 'Dedicated project teams', desc: 'You work with a consistent team who knows your project — not a rotating roster of freelancers.' },
          { title: 'WCAG/ADA compliance built-in', desc: 'Every site passes accessibility audits before handover. We are WCAG 2.1 AA, ADA, and Section 508 compliance specialists.' },
          { title: 'Transparent pricing', desc: 'Fixed-price projects with milestone-based billing. No hidden costs, no surprise invoices.' },
          { title: 'Performance-first development', desc: 'We target sub-2s load times and strong Core Web Vitals scores as baseline requirements.' },
          { title: 'Long-term support', desc: 'All packages include post-launch support. We also offer ongoing maintenance plans to keep your site healthy.' },
          { title: 'Real results, documented', desc: 'Our case studies show measurable outcomes — not vague claims. 200% more inquiries. 65% revenue from direct bookings.' },
        ].map(({ title, desc }) => (
          <li class="flex gap-4 rounded-2xl bg-[var(--bg)] border border-[var(--border)] p-6">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--accent)]/20 flex items-center justify-center mt-0.5" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <div>
              <p class="font-semibold text-[var(--text)]">{title}</p>
              <p class="mt-1 text-sm text-[var(--text-dim)]">{desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-24 text-center" aria-labelledby="about-cta-heading">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 id="about-cta-heading" class="font-heading text-3xl font-bold text-[var(--text)] sm:text-4xl">
        Ready to work with us?
      </h2>
      <p class="mt-4 text-lg text-[var(--text-dim)]">
        Let us bring our 24 years of experience to your next project.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/get-quote"
          class="inline-flex items-center justify-center rounded-xl bg-[var(--accent)] px-8 py-4 text-base font-semibold text-[var(--bg)] hover:opacity-90 transition-opacity"
        >
          Start Your Project
        </a>
        <a
          href="/portfolio"
          class="inline-flex items-center justify-center rounded-xl border border-[var(--border)] px-8 py-4 text-base font-semibold text-[var(--text)] hover:bg-[var(--bg-card)] transition-colors"
        >
          See Our Work
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
