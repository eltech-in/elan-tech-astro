---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import { integrations } from '../data/integrations';
import { cities } from '../data/cities';
import { breadcrumbSchema, serviceSchema, faqSchema } from '../utils/schema';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Integrations', href: '/integrations' },
];

const accent = '#0EA5E9'; // sky-500

const categories = [...new Set(integrations.map((i) => i.category))];

const getIconSvg = (iconName: string) => {
  const svgs: Record<string, string> = {
    Package: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
    Truck: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 00-2-2H4a2 2 0 00-2 2v11a1 1 0 001 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 001-1v-3.65a1 1 0 00-.22-.624l-3.48-4.35A1 1 0 0017.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>`,
    Globe: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
    Plane: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.2-1.1.6L2.5 9l5.4 3.1L6 14l-4.1-.5c-.4 0-.8.3-1 .7L0 16l6.3 3.1 3.1 6.3 1.8-.9c.4-.2.7-.6.7-1l-.5-4.1 1.9-1.9 3.1 5.4 2.2-1.2c.4-.2.7-.6.6-1.1z"/></svg>`,
    Rocket: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
    Box: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.3 7 12 12 20.7 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>`,
    MapPin: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    CreditCard: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
    Wallet: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 7V4a1 1 0 00-1-1H5a2 2 0 000 4h15a1 1 0 011 1v4h-3a2 2 0 000 4h3a1 1 0 001-1v-4"/><path d="M3 5v14a2 2 0 002 2h15"/></svg>`,
    Banknote: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>`,
    Smartphone: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    ShieldCheck: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
    ShoppingCart: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>`,
    Store: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  };
  return svgs[iconName] || svgs.Package;
};

const features = [
  'Payment Gateway Integration',
  'Shipping & Logistics APIs',
  'eCommerce Platform Setup',
  'ERP & CRM Connectivity',
  'Webhook & Event Handling',
  'Real-Time Data Sync',
  'Custom API Development',
];

const featuredCities = cities.filter((c) => c.isFeatured).slice(0, 6);

const integrationFaqs = [
  {
    question: 'How long does a typical integration take?',
    answer: 'Simple integrations like a payment gateway or shipping API typically take 1–2 weeks. Complex integrations involving custom middleware, data transformation, or multi-system synchronisation can take 3–6 weeks. We provide a timeline estimate during discovery after understanding your specific requirements.',
  },
  {
    question: 'Can you integrate with APIs not listed on this page?',
    answer: 'Absolutely. We work with any REST or GraphQL API that provides documentation. If you have an internal system, a niche SaaS tool, or a legacy ERP that needs connecting to your website, we can build the integration from scratch using the provider\'s API documentation.',
  },
  {
    question: 'Do you handle ongoing maintenance for integrations?',
    answer: 'Yes. APIs change — providers deprecate endpoints, update authentication methods, and modify response formats. Our maintenance plans include monitoring integration health, updating code when APIs change, and handling error recovery. This ensures your integrations remain reliable over time.',
  },
  {
    question: 'How do you ensure security in payment integrations?',
    answer: 'We follow PCI DSS guidelines, never store raw card data on your servers, use tokenisation for repeat payments, implement webhook signature verification, and set up HTTPS-only communication. All payment flows are tested end-to-end in sandbox environments before going live.',
  },
  {
    question: 'Can you connect multiple systems together?',
    answer: 'Yes — we frequently build middleware that connects your website to your CRM, ERP, accounting software, shipping provider, and payment gateway simultaneously. We design these integrations with proper error handling, retry logic, and logging so you have full visibility into data flow.',
  },
];

const schema = [
  serviceSchema('API & Third-Party Integrations', 'Connect your website with payment gateways, shipping APIs, CRMs, and eCommerce platforms for seamless automated workflows.', '/integrations'),
  faqSchema(integrationFaqs),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Integrations', url: '/integrations' },
  ]),
];
---
<ServiceLayout
  title="Third-Party API Integrations | eLan Technology"
  description="We integrate your website with leading payment gateways, shipping providers, eCommerce platforms, CRMs, and cloud services — seamlessly and securely."
  breadcrumbs={breadcrumbs}
  schema={schema}
>

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="relative mb-12 overflow-hidden rounded-2xl bg-gradient-to-br from-sky-500/10 via-[var(--bg-card)] to-[var(--bg-card)] p-8 md:p-12 border border-[var(--border)]">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest" style={`color: ${accent};`}>Seamless Third-Party Connections</p>
        <h1 class="font-heading text-3xl font-bold leading-tight text-[var(--text)] md:text-4xl lg:text-5xl">
          API Integrations — eLan Technology
        </h1>
        <p class="mt-4 text-base text-[var(--text-muted)] md:text-lg">
          We connect your website or application to the tools your business depends on — payment gateways, shipping carriers, eCommerce platforms, CRMs, and cloud services. Every integration is built with proper error handling, security, and monitoring so your data flows reliably.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/schedule-consultation" class="inline-flex items-center rounded-lg px-5 py-2.5 text-sm font-semibold text-white shadow transition hover:opacity-90" style={`background: ${accent};`}>
            Get Free Consultation
          </a>
          <a href="/get-quote" class="inline-flex items-center rounded-lg border border-[var(--border)] px-5 py-2.5 text-sm font-semibold text-[var(--text)] transition hover:bg-[var(--bg)]">
            Get a Quote
          </a>
        </div>
      </div>
      <ul class="space-y-3">
        {features.map((f) => (
          <li class="flex items-center gap-3 rounded-lg bg-[var(--bg)] px-4 py-3 border border-[var(--border)] text-sm font-medium text-[var(--text)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {f}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── INTEGRATIONS BY CATEGORY ─────────────────────────────────────────── -->
  {categories.map((category) => (
    <section class="mb-16">
      <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-2">{category}</h2>
      <p class="text-[var(--text-muted)] mb-8">
        {category === 'Shipping & Logistics' && 'We integrate with leading courier and logistics providers to automate order fulfilment, real-time tracking, and shipping label generation.'}
        {category === 'Payment Gateways' && 'Secure payment processing with UPI, cards, net banking, wallets, and international payment methods — fully tested before going live.'}
        {category === 'eCommerce & ERP' && 'Connect your website to eCommerce platforms, marketplaces, and ERP systems for automated inventory, order, and catalogue management.'}
      </p>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {integrations.filter((item) => item.category === category).map((item) => (
          <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-5 hover:border-[var(--accent)]/40 transition-colors duration-200">
            <div class="mb-3 inline-flex h-11 w-11 items-center justify-center rounded-xl" style={`background: ${accent}20; color: ${accent};`} set:html={getIconSvg(item.icon)} />
            <h3 class="font-heading text-base font-semibold text-[var(--text)] mb-2">{item.name}</h3>
            <p class="text-sm text-[var(--text-muted)] leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </section>
  ))}

  <!-- ── HOW WE INTEGRATE ─────────────────────────────────────────────────── -->
  <section class="mb-16 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-8 md:p-10">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-3">Our Integration Process</h2>
    <p class="text-[var(--text-muted)] mb-8">Every integration follows a structured process to ensure reliability, security, and maintainability.</p>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { n: '1', step: 'Discovery & Scoping', desc: 'We review your requirements, audit the third-party API documentation, identify data flows, and map out the integration architecture before writing any code.' },
        { n: '2', step: 'Sandbox Development', desc: 'Integration is built and tested in sandbox/staging environments with mock data. We implement proper error handling, retries, logging, and webhook verification.' },
        { n: '3', step: 'Testing & QA', desc: 'End-to-end testing covers success flows, failure scenarios, edge cases, and load testing. Payment integrations undergo PCI compliance verification.' },
        { n: '4', step: 'Deploy & Monitor', desc: 'Integration goes live with monitoring dashboards, alerting on failures, and documentation for your team. Ongoing maintenance keeps everything running smoothly.' },
      ].map(({ n, step, desc }) => (
        <div class="rounded-xl bg-[var(--bg)] border border-[var(--border)] p-5">
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-full font-heading text-sm font-bold text-white" style={`background: ${accent};`}>
            {n}
          </div>
          <h3 class="font-heading text-base font-semibold text-[var(--text)] mb-2">{step}</h3>
          <p class="text-sm text-[var(--text-muted)]">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────────────────────── -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold text-[var(--text)] md:text-3xl mb-8">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {integrationFaqs.map((faq) => (
        <details class="group rounded-xl border border-[var(--border)] bg-[var(--bg-card)]">
          <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 text-left font-heading text-base font-semibold text-[var(--text)] [&::-webkit-details-marker]:hidden">
            {faq.question}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </summary>
          <div class="px-5 pb-5 text-sm text-[var(--text-muted)] leading-relaxed">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- ── CITY LINKS ───────────────────────────────────────────────────────── -->
  <section class="mb-16 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-8">
    <h2 class="font-heading text-lg font-bold text-[var(--text)] mb-4">API Integration Services Near You</h2>
    <div class="flex flex-wrap gap-3">
      {featuredCities.map((city) => (
        <a
          href={city.landingPage || '/contact'}
          class="inline-flex items-center rounded-full border border-[var(--border)] px-4 py-2 text-sm text-[var(--text-muted)] transition hover:border-[var(--accent)] hover:text-[var(--accent)]"
        >
          API Integration in {city.name}
        </a>
      ))}
    </div>
  </section>

  <!-- ── DOUBLE CTA ───────────────────────────────────────────────────────── -->
  <section class="mb-4 grid gap-6 md:grid-cols-2">
    <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-8 text-center">
      <h3 class="font-heading text-xl font-bold text-[var(--text)] mb-3">Need a Custom Integration?</h3>
      <p class="text-sm text-[var(--text-muted)] mb-5">Don't see your provider listed? Our team can build custom API integrations for any platform.</p>
      <a href="/free-website-audit" class="inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold text-white shadow transition hover:opacity-90" style={`background: ${accent};`}>
        Get Free Audit
      </a>
    </div>
    <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-8 text-center">
      <h3 class="font-heading text-xl font-bold text-[var(--text)] mb-3">Ready to Connect Your Systems?</h3>
      <p class="text-sm text-[var(--text-muted)] mb-5">Book a free 30-minute consultation and we'll scope your integration requirements.</p>
      <a href="/schedule-consultation" class="inline-flex items-center justify-center rounded-full border-2 px-6 py-3 text-sm font-semibold transition hover:opacity-90" style={`border-color: ${accent}; color: ${accent};`}>
        Schedule a Consultation
      </a>
    </div>
  </section>

</ServiceLayout>
