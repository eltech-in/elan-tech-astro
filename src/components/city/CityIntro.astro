---
import type { CityData } from '../../data/cities';

interface Props {
  city: CityData;
}

const { city } = Astro.props;
---

<section class="py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] mb-6">
        {city.isHQ
          ? `Why Choose a Local Web Design Company in ${city.name}?`
          : `Why ${city.name} Businesses Choose a Nagpur-Based Web Agency`}
      </h2>
      <div class="space-y-5 text-[var(--text-dim)] leading-relaxed">
        <p set:html={city.introContent} />
      </div>
    </div>
  </div>
</section>
