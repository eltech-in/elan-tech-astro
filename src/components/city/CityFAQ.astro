---
import type { CityData } from '../../data/cities';

interface Props {
  city: CityData;
}

const { city } = Astro.props;
---

{city.faq.length > 0 && (
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="mb-10 text-center">
          <h2 class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] mb-4">
            Frequently Asked Questions — Web Design in {city.name}
          </h2>
          <p class="text-[var(--text-dim)]">
            Common questions from {city.name} businesses about our web design and digital marketing services.
          </p>
        </div>
        <div class="divide-y divide-[var(--border)]">
          {city.faq.map((item) => (
            <details class="py-4 group">
              <summary class="cursor-pointer list-none flex items-center justify-between font-medium text-[var(--text)] py-1 hover:text-[var(--accent)] transition-colors">
                <span>{item.question}</span>
                <svg
                  class="ml-4 h-5 w-5 shrink-0 text-[var(--text-muted)] transition-transform duration-200 group-open:rotate-180"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </summary>
              <p class="mt-3 text-[var(--text-dim)] leading-relaxed pr-8">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>
)}
