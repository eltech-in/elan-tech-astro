---
import type { CityData } from '../../data/cities';

interface Props {
  city: CityData;
}

const { city } = Astro.props;

const whatsappMsg = encodeURIComponent(`Hi eLan Technology, I'm a ${city.name} business interested in web design services`);
---

<section class="py-16 md:py-20 bg-[var(--bg-card)]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="mb-10 text-center">
        <h2 class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] mb-4">
          Get in Touch — {city.name}
        </h2>
        <p class="text-[var(--text-dim)] max-w-2xl mx-auto">
          {city.isHQ
            ? `Visit our ${city.name} headquarters or contact us today for a free website audit and no-obligation consultation.`
            : `We serve ${city.name} businesses remotely with seamless communication via Slack, Zoom, and project management tools. Contact us for a free website audit.`
          }
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 mb-10">
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg)] p-6">
          <h3 class="font-heading font-bold text-[var(--text)] mb-4">
            {city.isHQ ? `Our ${city.name} Office` : 'Our Office (Nagpur HQ)'}
          </h3>
          <address class="not-italic text-[var(--text-dim)] space-y-2 text-sm leading-relaxed">
            <p>Basement Floor, PTG IT Park</p>
            <p>Plot No. 21, IT Park Road</p>
            <p>Gayatri Nagar, Nagpur 440022</p>
            <p>Maharashtra, India</p>
          </address>
          {!city.isHQ && (
            <p class="mt-3 text-sm text-[var(--text-muted)]">
              {city.name} clients served remotely via video call & WhatsApp
            </p>
          )}
          {city.isHQ && (
            <a
              href="https://maps.google.com/?q=PTG+IT+Park+Gayatri+Nagar+Nagpur"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1 text-sm text-[var(--accent)] hover:underline"
            >
              View on Google Maps
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          )}
        </div>
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg)] p-6">
          <h3 class="font-heading font-bold text-[var(--text)] mb-4">Get in Touch</h3>
          <div class="space-y-3 text-sm">
            <a
              href={`https://wa.me/918788834630?text=${whatsappMsg}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-[var(--text-dim)] hover:text-[var(--accent)] transition-colors"
              aria-label="WhatsApp eLan Technology"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              <span>WhatsApp: +91-8788834630</span>
            </a>
            <a
              href="mailto:info@elan-tech.net"
              class="flex items-center gap-3 text-[var(--text-dim)] hover:text-[var(--accent)] transition-colors"
              aria-label="Email eLan Technology"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span>info@elan-tech.net</span>
            </a>
            <a
              href="tel:+918788834630"
              class="flex items-center gap-3 text-[var(--text-dim)] hover:text-[var(--accent)] transition-colors"
              aria-label="Call eLan Technology at +91 8788834630"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>+91-8788834630</span>
            </a>
          </div>
        </div>
      </div>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/get-quote"
          class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-3 font-semibold text-[#0A0E1A] hover:opacity-90 transition-opacity"
        >
          Get a Free Quote
        </a>
        <a
          href="/schedule-consultation"
          class="inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--bg)] px-8 py-3 font-semibold text-[var(--text)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
        >
          Schedule a Call
        </a>
      </div>
    </div>
  </div>
</section>
