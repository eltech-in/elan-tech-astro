---
import ThemeToggle from '../islands/ThemeToggle';
import MobileNav from '../islands/MobileNav';
import MegaMenu from '../islands/MegaMenu';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Blog', href: '/blog' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---
<header
  class="sticky top-0 z-50 w-full border-b border-[var(--border)] bg-[var(--bg-card)]/95 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">

    <!-- Logo (dual: full logo ↔ horizontal stamp on scroll) -->
    <a href="/" class="flex shrink-0 items-center gap-2" aria-label="eLan Technology — home">
      <span class="relative block" style="width:140px;height:40px;">
        <!-- Full logo — visible by default, fades out on scroll -->
        <img
          id="logo-full"
          src="/images/elan-tech-logo.svg"
          alt="eLan Technology"
          width="140"
          height="40"
          loading="eager"
          decoding="async"
          class="absolute inset-0 h-10 w-auto transition-all duration-500 ease-in-out"
          style="opacity:1;transform:scale(1);"
        />
        <!-- Horizontal compact logo — hidden by default, fades in on scroll -->
        <img
          id="logo-scrolled"
          src="/images/elan-tech-logoh.svg"
          alt="eLan Technology"
          width="140"
          height="40"
          loading="eager"
          decoding="async"
          class="absolute inset-0 h-10 w-auto transition-all duration-500 ease-in-out"
          style="opacity:0;transform:scale(1.1);"
        />
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-1">
      <a
        href="/"
        class:list={[
          'px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150',
          currentPath === '/'
            ? 'text-[var(--accent)]'
            : 'text-[var(--text-dim)] hover:text-[var(--text)]',
        ]}
      >
        Home
      </a>

      <a
        href="/about"
        class:list={[
          'px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150',
          currentPath === '/about'
            ? 'text-[var(--accent)]'
            : 'text-[var(--text-dim)] hover:text-[var(--text)]',
        ]}
      >
        About
      </a>

      <!-- Services — triggers MegaMenu island -->
      <a
        href="/services"
        data-mega="services"
        aria-haspopup="true"
        aria-expanded="false"
        class:list={[
          'flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150',
          currentPath.startsWith('/services') 
            ? 'text-[var(--accent)]' 
            : 'text-[var(--text-dim)] hover:text-[var(--text)]'
        ]}
      >
        Services
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="mt-px transition-transform duration-150"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </a>

      <!-- Products — triggers MegaMenu island -->
      <a
        href="/products"
        data-mega="products"
        aria-haspopup="true"
        aria-expanded="false"
        class:list={[
          'flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150',
          currentPath.startsWith('/products') 
            ? 'text-[var(--accent)]' 
            : 'text-[var(--text-dim)] hover:text-[var(--text)]'
        ]}
      >
        Products
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="mt-px transition-transform duration-150"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </a>

      {navLinks.slice(2).map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-[var(--accent)]'
              : 'text-[var(--text-dim)] hover:text-[var(--text)]',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right-side actions -->
    <div class="flex items-center gap-2">
      <!-- Island: ThemeToggle -->
      <ThemeToggle client:load />

      <!-- CTA button — desktop -->
      <a
        href="/free-website-audit"
        class="hidden sm:inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-4 py-2 text-sm font-semibold text-[#0A0E1A] transition-opacity duration-150 hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)]"
      >
        Get Free Audit
      </a>

      <!-- Island: MobileNav -->
      <MobileNav client:load />
    </div>
  </div>

  <!-- Island: MegaMenu -->
  <MegaMenu client:load />
</header>

<script>
  (function () {
    const header = document.querySelector('header') as HTMLElement | null;
    const logoFull = document.getElementById('logo-full') as HTMLImageElement | null;
    const logoScrolled = document.getElementById('logo-scrolled') as HTMLImageElement | null;
    if (!header || !logoFull || !logoScrolled) return;

    let ticking = false;

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrolled = window.scrollY > 20;
          // Header background transition
          if (scrolled) {
            header!.classList.add('header--scrolled');
          } else {
            header!.classList.remove('header--scrolled');
          }
          // Logo swap
          logoFull!.style.opacity = scrolled ? '0' : '1';
          logoFull!.style.transform = scrolled ? 'scale(0.9)' : 'scale(1)';
          logoScrolled!.style.opacity = scrolled ? '1' : '0';
          logoScrolled!.style.transform = scrolled ? 'scale(1)' : 'scale(1.1)';
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>

<style>
  header.header--scrolled {
    background-color: color-mix(in srgb, var(--bg-card) 92%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }
</style>
