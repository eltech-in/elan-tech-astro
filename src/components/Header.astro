---
import ThemeToggle from '../islands/ThemeToggle';
import MobileNav from '../islands/MobileNav';
import MegaMenu from '../islands/MegaMenu';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Blog', href: '/blog' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---
<header
  class="sticky top-0 z-50 w-full border-b border-[var(--border)] bg-[var(--bg-card)]/95 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">

    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center gap-2" aria-label="eLan Technology — home">
      <img
        src="/images/elan-tech-logo.svg"
        alt="eLan Technology"
        width="140"
        height="40"
        loading="eager"
        decoding="async"
        class="h-10 w-auto"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-1">
      <a
        href="/"
        class:list={[
          'px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150',
          currentPath === '/'
            ? 'text-[var(--accent)]'
            : 'text-[var(--text-dim)] hover:text-[var(--text)]',
        ]}
      >
        Home
      </a>

      <a
        href="/about"
        class:list={[
          'px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150',
          currentPath === '/about'
            ? 'text-[var(--accent)]'
            : 'text-[var(--text-dim)] hover:text-[var(--text)]',
        ]}
      >
        About
      </a>

      <!-- Services — triggers MegaMenu island -->
      <button
        type="button"
        data-mega="services"
        aria-haspopup="true"
        aria-expanded="false"
        class="flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium text-[var(--text-dim)] hover:text-[var(--text)] transition-colors duration-150"
      >
        Services
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="mt-px transition-transform duration-150"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>

      <!-- Products — triggers MegaMenu island -->
      <button
        type="button"
        data-mega="products"
        aria-haspopup="true"
        aria-expanded="false"
        class="flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium text-[var(--text-dim)] hover:text-[var(--text)] transition-colors duration-150"
      >
        Products
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="mt-px transition-transform duration-150"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>

      {navLinks.slice(2).map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-[var(--accent)]'
              : 'text-[var(--text-dim)] hover:text-[var(--text)]',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right-side actions -->
    <div class="flex items-center gap-2">
      <!-- Island: ThemeToggle -->
      <ThemeToggle client:media="(max-width:768px)" />

      <!-- CTA button — desktop -->
      <a
        href="/free-website-audit"
        class="hidden sm:inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-4 py-2 text-sm font-semibold text-[#0A0E1A] transition-opacity duration-150 hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)]"
      >
        Get Free Audit
      </a>

      <!-- Island: MobileNav -->
      <MobileNav client:load />
    </div>
  </div>

  <!-- Island: MegaMenu -->
  <MegaMenu client:load />
</header>
