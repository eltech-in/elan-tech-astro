---

<footer class="relative mt-16 bg-[var(--bg-card)] text-[var(--text-dim)]">
  <!-- Gradient top border -->
  <div class="h-px w-full bg-gradient-to-r from-[#00E5A0] via-[#6366F1] to-[#EC4899]"></div>

  <div class="mx-auto max-w-7xl px-4 pt-14 pb-10 sm:px-6 lg:px-8">
    <!-- 5-column grid -->
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-5">

      <!-- Col 1: Brand -->
      <div class="flex flex-col gap-5">
        <a href="/" aria-label="eLan Technology — home">
          <img
            src="/images/elan-tech-logo.svg"
            alt="eLan Technology"
            width="140"
            height="40"
            loading="lazy"
            decoding="async"
            class="h-10 w-auto"
          />
        </a>

        <p class="text-sm leading-relaxed">
          Award-winning web design &amp; digital marketing agency. Building impactful digital experiences since 2002.
        </p>

        <!-- Social icons -->
        <div class="flex flex-wrap gap-3" role="list" aria-label="Social media links">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              role="listitem"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--border)] text-[var(--text-muted)] transition-colors duration-150 hover:border-[var(--accent)] hover:text-[var(--accent)]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                focusable="false"
              >
                <path d={social.svgPath} />
              </svg>
            </a>
          ))}
        </div>

        <!-- Compliance badges -->
        <div class="flex flex-col gap-1 text-xs text-[var(--text-muted)]">
          <span>♿ WCAG 2.1 AA Compliant</span>
          <span>♿ ADA Compliant</span>
          <span>♿ Section 508 Compliant</span>
        </div>
      </div>

      <!-- Col 2: Services -->
      <div>
        <h3 class="mb-4 font-heading text-sm font-semibold uppercase tracking-wider text-[var(--text)]">
          Services
        </h3>
        <ul class="flex flex-col gap-2 text-sm">
          {services.map((service) => (
            <li>
              <a
                href={service.href || `/services/${service.slug}`}
                class="transition-colors duration-150 hover:text-[var(--accent)]"
              >
                {service.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Company -->
      <div>
        <h3 class="mb-4 font-heading text-sm font-semibold uppercase tracking-wider text-[var(--text)]">
          Company
        </h3>
        <ul class="flex flex-col gap-2 text-sm">
          {companyLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="transition-colors duration-150 hover:text-[var(--accent)]"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Locations -->
      <div>
        <h3 class="mb-4 font-heading text-sm font-semibold uppercase tracking-wider text-[var(--text)]">
          Locations
        </h3>
        <div class="space-y-4">
          <div>
            <h4 class="mb-2 text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)]">India</h4>
            <ul class="flex flex-col gap-1.5 text-sm">
              {featuredCities.map((city) => (
                <li>
                  <a
                    href={`/web-design-company-${city.slug}`}
                    class="transition-colors duration-150 hover:text-[var(--accent)]"
                  >
                    {city.name}{city.isHQ ? ' (HQ)' : ''}
                  </a>
                </li>
              ))}
              <li>
                <span class="text-xs text-[var(--text-muted)]">
                  + {citiesWithPages.length - featuredCities.length} more cities
                </span>
              </li>
            </ul>
          </div>
          <div>
            <h4 class="mb-2 text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)]">International</h4>
            <ul class="flex flex-col gap-1.5 text-sm">
              {internationalCountries.slice(0, 6).map((country) => (
                <li>
                  <a
                    href={`/web-design-company-${country.slug}`}
                    class="transition-colors duration-150 hover:text-[var(--accent)]"
                  >
                    {country.flag} {country.name}
                  </a>
                </li>
              ))}
              {internationalCountries.length > 6 && (
                <li>
                  <span class="text-xs text-[var(--text-muted)]">
                    + {internationalCountries.length - 6} more countries
                  </span>
                </li>
              )}
            </ul>
          </div>
        </div>
      </div>

      <!-- Col 5: Contact + Newsletter -->
      <div class="flex flex-col gap-5">
        <div>
          <h3 class="mb-4 font-heading text-sm font-semibold uppercase tracking-wider text-[var(--text)]">
            Contact
          </h3>
          <ul class="flex flex-col gap-3 text-sm">
            <li>
              <a
                href="https://wa.me/918788834630"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 transition-colors duration-150 hover:text-[var(--accent)]"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zm-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884zm8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
                +91 8788834630
              </a>
            </li>
            <li>
              <a
                href="mailto:info@elan-tech.net"
                class="flex items-center gap-2 transition-colors duration-150 hover:text-[var(--accent)]"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  focusable="false"
                >
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7" />
                </svg>
                info@elan-tech.net
              </a>
            </li>
            <li>
              <a
                href="https://maps.google.com/?q=PTG+IT+Park+Plot+No+21+IT+Park+Rd+Gayatri+Nagar+Nagpur+Maharashtra+440022"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-start gap-2 transition-colors duration-150 hover:text-[var(--accent)]"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  focusable="false"
                  class="mt-0.5 shrink-0"
                >
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
                <span>Nagpur, Maharashtra, India</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Newsletter form (static shell — NewsletterForm island replaces this in Step 3) -->
        <div>
          <h4 class="mb-3 text-sm font-semibold text-[var(--text)]">Newsletter</h4>
          <form action="/api/subscribe" method="POST" class="flex gap-2">
            <label for="footer-email" class="sr-only">Email address</label>
            <input
              id="footer-email"
              type="email"
              name="email"
              required
              placeholder="you@example.com"
              autocomplete="email"
              class="flex-1 min-w-0 rounded-lg border border-[var(--border)] bg-[var(--bg)] px-3 py-2 text-sm text-[var(--text)] placeholder-[var(--text-muted)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)]"
            />
            <button
              type="submit"
              class="rounded-lg bg-[var(--accent)] px-4 py-2 text-sm font-semibold text-[#0A0E1A] transition-opacity duration-150 hover:opacity-90"
            >
              Join
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 border-t border-[var(--border)] pt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-[var(--text-muted)]">
        &copy; 2002&ndash;{year} eLan Technology. All rights reserved.
      </p>
      <nav aria-label="Legal links" class="flex flex-wrap gap-x-4 gap-y-1">
        {legalLinks.map((link) => (
          <a
            href={link.href}
            class="text-xs text-[var(--text-muted)] transition-colors duration-150 hover:text-[var(--accent)]"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>
