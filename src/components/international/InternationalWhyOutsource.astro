---
import type { CountryData } from '../../data/countries';

interface Props {
  country: CountryData;
}

const { country } = Astro.props;

const reasons = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
    title: `Save ${country.costComparison.savings} on Development`,
    desc: `${country.name} agencies charge ${country.costComparison.localCost}. eLan delivers the same quality for ${country.costComparison.eLanCost} — using React, Next.js, Astro, WordPress, and Shopify.`,
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    title: 'Timezone Overlap',
    desc: country.timezoneOverlap + '. We schedule calls during your business hours and use Slack for async communication throughout the day.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    title: `${country.accessibilityLaw} Compliance`,
    desc: `Every website meets WCAG 2.1 AA standards, ensuring compliance with ${country.accessibilityLaw}. Accessibility is included in every project — never an add-on.`,
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
    title: '24+ Years, 500+ Clients',
    desc: 'Operating since 2002 with clients across 25+ countries. Our experience spans healthcare, finance, education, eCommerce, SaaS, and more.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>',
    title: `${country.language} Communication`,
    desc: `Our team communicates fluently in ${country.language}. Daily updates via Slack, weekly video calls on Zoom, and transparent project tracking on Jira or Asana.`,
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    title: 'Modern Technology Stack',
    desc: 'React, Next.js, Astro, Node.js, MongoDB, WordPress, Shopify, Flutter — the same technologies used by leading agencies worldwide.',
  },
];
---

<section class="py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-[var(--text)] mb-4">
        Why {country.name} Businesses Choose eLan Technology
      </h2>
      <p class="text-[var(--text-dim)] max-w-2xl mx-auto">
        Get world-class web design at a fraction of {country.name} agency prices — with no compromise on quality, communication, or compliance.
      </p>
    </div>
    <ul role="list" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {reasons.map((r) => (
        <li class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-6">
          <div class="mb-3 text-[var(--accent)]" aria-hidden="true" set:html={r.icon} />
          <h3 class="font-heading font-semibold text-[var(--text)] mb-2">{r.title}</h3>
          <p class="text-sm text-[var(--text-dim)] leading-relaxed">{r.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
