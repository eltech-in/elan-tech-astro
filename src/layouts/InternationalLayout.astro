---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import type { CountryData } from '../data/countries';
import { serviceSchema, faqSchema, breadcrumbSchema } from '../utils/schema';

interface Props {
  country: CountryData;
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  extraSchema?: object[];
}

const {
  country,
  title = `Outsource Web Design to India from ${country.name} | eLan Technology`,
  description = `Affordable, high-quality web design & development for ${country.name} businesses. Save ${country.costComparison.savings} vs local agencies. WCAG compliant. Since 2002.`,
  canonical,
  ogImage,
  noindex,
  extraSchema = [],
} = Astro.props;

const pageUrl = `/web-design-company-${country.slug}`;

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'International', href: '/services' },
  { name: country.name, href: pageUrl },
];

// Build schemas — Service schema for international (not LocalBusiness)
const svc = serviceSchema(
  `Web Design & Development Services for ${country.name}`,
  `Professional web design, development, and digital marketing services for ${country.name} businesses. Save ${country.costComparison.savings} compared to local ${country.name} agencies.`,
  `https://elan-tech.net${pageUrl}`
);
const faq = country.faq.length > 0 ? faqSchema(country.faq) : null;
const crumbSchema = breadcrumbSchema(
  breadcrumbs.map((b) => ({ name: b.name, url: b.href }))
);

const allSchemas = [svc, crumbSchema, ...(faq ? [faq] : []), ...extraSchema];
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical ?? `https://elan-tech.net${pageUrl}`}
  ogImage={ogImage}
  schema={allSchemas}
  noindex={noindex}
>
  <!-- International Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[var(--bg)] to-[var(--bg-card)] px-4 py-20 sm:px-6 lg:px-8">
    <!-- Background accent glow -->
    <div
      class="pointer-events-none absolute -top-40 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-[var(--accent)]/10 blur-3xl"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-4xl text-center">
      <!-- Breadcrumb -->
      <div class="mb-6 flex justify-center">
        <Breadcrumb items={breadcrumbs} />
      </div>

      <!-- Country flag + badge -->
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-[var(--accent)]">
        <span class="mr-1 text-lg" aria-hidden="true">{country.flag}</span>
        Serving {country.name} businesses
      </p>

      <h1 class="font-heading text-4xl font-bold leading-tight text-[var(--text)] sm:text-5xl lg:text-6xl">
        Web Design & Development for {country.name}
      </h1>

      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-[var(--text-dim)]">
        High-quality websites at a fraction of {country.name} agency prices. Save {country.costComparison.savings} with India's most experienced web design company.
      </p>

      <!-- Key stats -->
      <div class="mt-6 flex flex-wrap items-center justify-center gap-6 text-sm text-[var(--text-muted)]">
        <span>{country.timezoneOverlap}</span>
        <span class="hidden sm:inline" aria-hidden="true">·</span>
        <span>24+ years experience</span>
        <span class="hidden sm:inline" aria-hidden="true">·</span>
        <span>500+ clients in 25+ countries</span>
      </div>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/free-website-audit"
          class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-3 text-base font-semibold text-[#0A0E1A] shadow-lg transition-opacity duration-150 hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)] focus-visible:outline-offset-2"
        >
          Get Free Audit
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a
          href="/get-quote"
          class="inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--bg-card)] px-8 py-3 text-base font-semibold text-[var(--text)] transition-colors duration-150 hover:border-[var(--accent)] hover:text-[var(--accent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)] focus-visible:outline-offset-2"
        >
          Get Quote
        </a>
      </div>
    </div>
  </section>

  <!-- Page content -->
  <slot />
</BaseLayout>
