---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  schema?: object | object[];
  city: string;
  state: string;
  heroHeading: string;
  heroSubtext: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  schema,
  city,
  state,
  heroHeading,
  heroSubtext,
} = Astro.props;

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services' },
  { name: city, href: Astro.url.pathname },
];
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType={ogType}
  noindex={noindex}
  schema={schema}
>
  <!-- City Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[var(--bg)] to-[var(--bg-card)] px-4 py-20 sm:px-6 lg:px-8">
    <!-- Background accent glow -->
    <div
      class="pointer-events-none absolute -top-40 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-[var(--accent)]/10 blur-3xl"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-4xl text-center">
      <!-- Breadcrumb inside hero -->
      <div class="mb-6 flex justify-center">
        <Breadcrumb items={breadcrumbs} />
      </div>

      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-[var(--accent)]">
        {city}, {state}
      </p>

      <h1 class="font-heading text-4xl font-bold leading-tight text-[var(--text)] sm:text-5xl lg:text-6xl">
        {heroHeading}
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-[var(--text-dim)]">
        {heroSubtext}
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/free-website-audit"
          class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-3 text-base font-semibold text-[#0A0E1A] shadow-lg transition-opacity duration-150 hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)] focus-visible:outline-offset-2"
        >
          Get Free Audit
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>

        <a
          href="/get-quote"
          class="inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--bg-card)] px-8 py-3 text-base font-semibold text-[var(--text)] transition-colors duration-150 hover:border-[var(--accent)] hover:text-[var(--accent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)] focus-visible:outline-offset-2"
        >
          Get Quote
        </a>
      </div>
    </div>
  </section>

  <!-- Page content -->
  <slot />

  <!-- Schema slot for page-level JSON-LD -->
  <slot name="schema" />
</BaseLayout>
