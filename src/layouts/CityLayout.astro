---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import type { CityData } from '../data/cities';
import { localBusinessSchema, faqSchema, breadcrumbSchema } from '../utils/schema';

// Support both new CityData-based props AND legacy string-based props
interface Props {
  // New interface (preferred)
  city?: CityData | string;
  // Legacy props (backward compat — will be removed after Step 3 migration)
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  schema?: object | object[];
  state?: string;
  heroHeading?: string;
  heroSubtext?: string;
  extraSchema?: object[];
}

// ISO 3166-2:IN state codes for geo meta tags
const stateISOCodes: Record<string, string> = {
  'Maharashtra': 'IN-MH', 'Chhattisgarh': 'IN-CT', 'Telangana': 'IN-TG',
  'Delhi NCR': 'IN-DL', 'Karnataka': 'IN-KA', 'Tamil Nadu': 'IN-TN',
  'Madhya Pradesh': 'IN-MP', 'West Bengal': 'IN-WB', 'Gujarat': 'IN-GJ',
  'Rajasthan': 'IN-RJ', 'Uttar Pradesh': 'IN-UP', 'Punjab / Haryana': 'IN-PB',
  'Kerala': 'IN-KL',
};

const props = Astro.props;
const isLegacy = typeof props.city === 'string' || !props.city;

// ── Legacy mode (existing pages that pass string props) ──────────────
if (isLegacy) {
  // Just pass through to BaseLayout with legacy props
  var legacyMode = true;
  var legacyTitle = props.title ?? '';
  var legacyDescription = props.description ?? '';
  var legacyCanonical = props.canonical;
  var legacyOgImage = props.ogImage;
  var legacyOgType = props.ogType;
  var legacyNoindex = props.noindex;
  var legacySchema = props.schema;
  var legacyCity = (props.city as string) ?? '';
  var legacyState = props.state ?? '';
  var legacyHeroHeading = props.heroHeading ?? '';
  var legacyHeroSubtext = props.heroSubtext ?? '';
  var legacyBreadcrumbs = [
    { name: 'Home', href: '/' },
    { name: 'Services', href: '/services' },
    { name: legacyCity, href: Astro.url.pathname },
  ];
}

// ── New mode (CityData object) ────────────────────────────────────────
const city = !isLegacy ? (props.city as CityData) : null;
const pageUrl = city ? `/web-design-company-${city.slug}` : '';

const title = city
  ? (props.title ?? `Best Web Design Company in ${city.name} | eLan Technology`)
  : legacyTitle;
const description = city
  ? (props.description ?? `Top-rated web design & development company in ${city.name}, ${city.state}. ${city.tagline}. WCAG 2.1 AA compliant. 500+ clients. Since 2002.`)
  : legacyDescription;

const breadcrumbs = city
  ? [
      { name: 'Home', href: '/' },
      { name: 'Web Design Company', href: '/services' },
      { name: city.name, href: pageUrl },
    ]
  : legacyBreadcrumbs;

// Build schemas for new mode
let allSchemas: any = legacySchema;
if (city) {
  const localBiz = localBusinessSchema(city.name, {
    city: city.name,
    geo: { latitude: city.geo.lat, longitude: city.geo.lng },
    url: `https://elan-tech.net${pageUrl}`,
    description: `Professional web design & digital marketing services in ${city.name}. WCAG/ADA compliant websites. Since 2002.`,
  });
  const faq = city.faq.length > 0 ? faqSchema(city.faq) : null;
  const crumbSchema = breadcrumbSchema(
    breadcrumbs.map((b) => ({ name: b.name, url: b.href }))
  );
  allSchemas = [localBiz, crumbSchema, ...(faq ? [faq] : []), ...(props.extraSchema ?? [])];
}

const trustLine = city
  ? city.isHQ
    ? 'Nagpur headquarters · 24+ years · 500+ clients · 25+ countries'
    : `${city.distanceFromNagpur} from our Nagpur HQ · 24+ years · 500+ clients`
  : '';

const heroHeading = city ? `Best Web Design Company in ${city.name}` : legacyHeroHeading;
const heroSubtext = city ? city.tagline : legacyHeroSubtext;
const badge = city
  ? city.isHQ ? `Headquartered in ${city.name}` : `Serving ${city.name} businesses`
  : `${legacyCity}, ${legacyState}`;
---
<BaseLayout
  title={title}
  description={description}
  canonical={city ? `https://elan-tech.net${pageUrl}` : props.canonical}
  ogImage={props.ogImage}
  ogType={props.ogType}
  schema={allSchemas}
  noindex={props.noindex}
  geo={city ? { region: stateISOCodes[city.state] ?? 'IN', placename: city.name, lat: city.geo.lat, lng: city.geo.lng } : undefined}
>
  <!-- City Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[var(--bg)] to-[var(--bg-card)] px-4 py-20 sm:px-6 lg:px-8">
    <div
      class="pointer-events-none absolute -top-40 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-[var(--accent)]/10 blur-3xl"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-4xl text-center">
      <div class="mb-6 flex justify-center">
        <Breadcrumb items={breadcrumbs} />
      </div>

      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-[var(--accent)]">
        {badge}
      </p>

      <h1 class="font-heading text-4xl font-bold leading-tight text-[var(--text)] sm:text-5xl lg:text-6xl">
        {heroHeading}
      </h1>

      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-[var(--text-dim)]">
        {heroSubtext}
      </p>

      {trustLine && (
        <p class="mt-3 text-sm text-[var(--text-muted)]">
          {trustLine}
        </p>
      )}

      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/free-website-audit"
          class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-8 py-3 text-base font-semibold text-[#0A0E1A] shadow-lg transition-opacity duration-150 hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)] focus-visible:outline-offset-2"
        >
          Get Free Audit
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a
          href="/get-quote"
          class="inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--bg-card)] px-8 py-3 text-base font-semibold text-[var(--text)] transition-colors duration-150 hover:border-[var(--accent)] hover:text-[var(--accent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)] focus-visible:outline-offset-2"
        >
          Get Quote
        </a>
      </div>
    </div>
  </section>

  <slot />
</BaseLayout>
