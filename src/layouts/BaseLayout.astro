---
import SEOHead from '../components/SEOHead.astro';
import SkipLink from '../components/SkipLink.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import StickyContactBar from '../components/StickyContactBar.astro';
import '../styles/globals.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  schema?: object | object[];
}

const { title, description, canonical, ogImage, ogType, noindex, schema } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      schema={schema}
    />
  </head>
  <body class="bg-[var(--bg)] text-[var(--text)] font-sans antialiased">
    <SkipLink />
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <!-- Desktop: floating WhatsApp. Mobile: sticky bottom bar (Call + WhatsApp) -->
    <WhatsAppFloat />
    <StickyContactBar />
    <!-- Mobile bottom bar spacer so footer content isn't hidden behind sticky bar -->
    <div class="h-14 lg:hidden" aria-hidden="true"></div>
  </body>
</html>
